<%- include('partials/header') %>

    <div class="container text-center py-5">
        <div class="row justify-content-center">
            <div class="col-md-8">
                <h1 class="display-1 text-danger">500</h1>
                <h2 class="mb-4">Server Error</h2>
                <p class="lead mb-4">Something went wrong on our end. We're working to fix it.</p>

                <% if (error && process.env.NODE_ENV==='development' ) { %>
                    <div class="alert alert-danger text-start">
                        <strong>Error Details (Development Only):</strong>
                        <pre class="mt-2 mb-0"><%= error %></pre>
                    </div>
                    <% } %>

                        <div class="mt-4">
                            <a href="/" class="btn btn-primary btn-lg">
                                <i class="fas fa-home"></i> Go to Homepage
                            </a>
                            <button onclick="location.reload()" class="btn btn-outline-secondary btn-lg ms-2">
                                <i class="fas fa-sync-alt"></i> Try Again
                            </button>
                        </div>
            </div>
        </div>
    </div>

    <%- include('partials/footer') %>