<%- include('../partials/header') %>

    <div class="transactions-container">
        <div class="container">
            <!-- Header -->
            <div class="transactions-header">
                <div class="row align-items-center">
                    <div class="col-md-6">
                        <a href="/wallet" class="back-link">
                            <i class="fas fa-arrow-left"></i> Back to Wallet
                        </a>
                        <h1 class="transactions-title">Transaction History</h1>
                        <p class="transactions-subtitle">View all your financial activities</p>
                    </div>
                    <div class="col-md-6 text-md-end">
                        <div class="balance-summary">
                            <span>Current Balance:</span>
                            <strong>₹<%= user.walletBalance.toFixed(2) %></strong>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Summary Cards -->
            <div class="summary-cards">
                <div class="row">
                    <div class="col-md-3">
                        <div class="summary-card deposits">
                            <div class="summary-icon">
                                <i class="fas fa-arrow-down"></i>
                            </div>
                            <div class="summary-details">
                                <span class="summary-label">Total Deposits</span>
                                <span class="summary-value">₹<%= (summary.totalDeposits || 0).toFixed(2) %></span>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-3">
                        <div class="summary-card withdrawals">
                            <div class="summary-icon">
                                <i class="fas fa-arrow-up"></i>
                            </div>
                            <div class="summary-details">
                                <span class="summary-label">Total Withdrawals</span>
                                <span class="summary-value">₹<%= (summary.totalWithdrawals || 0).toFixed(2) %></span>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-3">
                        <div class="summary-card bets">
                            <div class="summary-icon">
                                <i class="fas fa-gamepad"></i>
                            </div>
                            <div class="summary-details">
                                <span class="summary-label">Total Bets</span>
                                <span class="summary-value">₹<%= (summary.totalBets || 0).toFixed(2) %></span>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-3">
                        <div class="summary-card wins">
                            <div class="summary-icon">
                                <i class="fas fa-trophy"></i>
                            </div>
                            <div class="summary-details">
                                <span class="summary-label">Total Wins</span>
                                <span class="summary-value">₹<%= (summary.totalWins || 0).toFixed(2) %></span>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Filters -->
            <div class="filters-card">
                <div class="row align-items-center">
                    <div class="col-md-4">
                        <select class="form-control filter-select" id="typeFilter">
                            <option value="all">All Transactions</option>
                            <option value="deposit">Deposits</option>
                            <option value="withdrawal">Withdrawals</option>
                            <option value="bet">Bets</option>
                            <option value="win">Wins</option>
                            <option value="refund">Refunds</option>
                        </select>
                    </div>
                    <div class="col-md-4">
                        <select class="form-control filter-select" id="statusFilter">
                            <option value="all">All Status</option>
                            <option value="completed">Completed</option>
                            <option value="pending">Pending</option>
                            <option value="failed">Failed</option>
                        </select>
                    </div>
                    <div class="col-md-4">
                        <div class="date-range">
                            <input type="date" class="form-control" id="startDate" placeholder="Start Date">
                            <span>to</span>
                            <input type="date" class="form-control" id="endDate" placeholder="End Date">
                        </div>
                    </div>
                </div>
            </div>

            <!-- Transactions List -->
            <div class="transactions-card">
                <% if (transactions && transactions.length> 0) { %>
                    <div class="transactions-list">
                        <% transactions.forEach(transaction=> { %>
                            <div class="transaction-item" data-type="<%= transaction.type %>"
                                data-status="<%= transaction.status %>"
                                data-date="<%= new Date(transaction.createdAt).toISOString().split('T')[0] %>">

                                <div class="transaction-icon <%= transaction.type %>">
                                    <% if (transaction.type==='deposit' ) { %>
                                        <i class="fas fa-arrow-down"></i>
                                        <% } else if (transaction.type==='withdrawal' ) { %>
                                            <i class="fas fa-arrow-up"></i>
                                            <% } else if (transaction.type==='bet' ) { %>
                                                <i class="fas fa-gamepad"></i>
                                                <% } else if (transaction.type==='win' ) { %>
                                                    <i class="fas fa-trophy"></i>
                                                    <% } else if (transaction.type==='refund' ) { %>
                                                        <i class="fas fa-undo-alt"></i>
                                                        <% } %>
                                </div>

                                <div class="transaction-details">
                                    <div class="transaction-header">
                                        <h4 class="transaction-title">
                                            <%= transaction.description || transaction.type.charAt(0).toUpperCase() +
                                                transaction.type.slice(1) %>
                                        </h4>
                                        <span class="transaction-id">ID: <%= transaction._id.toString().slice(-8) %>
                                        </span>
                                    </div>

                                    <div class="transaction-meta">
                                        <span class="transaction-date">
                                            <i class="far fa-calendar"></i>
                                            <%= new Date(transaction.createdAt).toLocaleDateString('en-IN', {
                                                day: 'numeric' , month: 'short' , year: 'numeric' , hour: '2-digit' ,
                                                minute: '2-digit' }) %>
                                        </span>

                                        <% if (transaction.game) { %>
                                            <span class="transaction-game">
                                                <i class="fas fa-dice"></i>
                                                Game #<%= transaction.game.roomId ||
                                                    transaction.game.toString().slice(-6) %>
                                            </span>
                                            <% } %>
                                    </div>

                                    <% if (transaction.paymentMethod) { %>
                                        <div class="transaction-payment">
                                            <i class="fas fa-credit-card"></i>
                                            <%= transaction.paymentMethod %>
                                        </div>
                                        <% } %>
                                </div>

                                <div class="transaction-amount-section">
                                    <div class="transaction-amount <%= transaction.type %>">
                                        <%= transaction.type==='withdrawal' || transaction.type==='bet' ? '-' : '+' %>
                                            ₹<%= transaction.amount.toFixed(2) %>
                                    </div>
                                    <div class="transaction-balance">
                                        Balance: ₹<%= transaction.balanceAfter.toFixed(2) %>
                                    </div>
                                    <div class="transaction-status">
                                        <span class="status-badge <%= transaction.status %>">
                                            <%= transaction.status %>
                                        </span>
                                    </div>
                                </div>
                            </div>
                            <% }) %>
                    </div>

                    <!-- Pagination -->
                    <% if (pagination && pagination.pages> 1) { %>
                        <nav class="pagination-nav">
                            <ul class="pagination">
                                <li class="page-item <%= pagination.page === 1 ? 'disabled' : '' %>">
                                    <a class="page-link" href="?page=<%= pagination.page - 1 %>">
                                        <i class="fas fa-chevron-left"></i>
                                    </a>
                                </li>

                                <% for(let i=1; i <=pagination.pages; i++) { %>
                                    <li class="page-item <%= pagination.page === i ? 'active' : '' %>">
                                        <a class="page-link" href="?page=<%= i %>">
                                            <%= i %>
                                        </a>
                                    </li>
                                    <% } %>

                                        <li
                                            class="page-item <%= pagination.page === pagination.pages ? 'disabled' : '' %>">
                                            <a class="page-link" href="?page=<%= pagination.page + 1 %>">
                                                <i class="fas fa-chevron-right"></i>
                                            </a>
                                        </li>
                            </ul>
                        </nav>
                        <% } %>
                            <% } else { %>
                                <div class="empty-state">
                                    <i class="fas fa-exchange-alt fa-4x text-muted mb-4"></i>
                                    <h3>No Transactions Yet</h3>
                                    <p class="text-muted">Your transaction history will appear here</p>
                                    <a href="/games" class="btn btn-primary mt-3">
                                        <i class="fas fa-gamepad me-2"></i>Start Playing
                                    </a>
                                </div>
                                <% } %>
            </div>
        </div>
    </div>

    <style>
        /* Summary Cards */
        .summary-cards {
            margin-bottom: 30px;
        }

        .summary-card {
            background: white;
            border-radius: 15px;
            padding: 20px;
