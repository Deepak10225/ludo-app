            box-shadow: 0 5px 15px rgba(0, 0, 0, 0.05);
            transition: all 0.3s ease;
        }

        .summary-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 10px 25px rgba(0, 0, 0, 0.1);
        }

        .summary-card.deposits {
            border-left: 4px solid #1cc88a;
        }

        .summary-card.withdrawals {
            border-left: 4px solid #e74a3b;
        }

        .summary-card.bets {
            border-left: 4px solid #f6c23e;
        }

        .summary-card.wins {
            border-left: 4px solid #667eea;
        }

        .summary-icon {
            width: 50px;
            height: 50px;
            border-radius: 10px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.5rem;
            color: white;
        }

        .summary-card.deposits .summary-icon {
            background: linear-gradient(135deg, #1cc88a 0%, #17a673 100%);
        }

        .summary-card.withdrawals .summary-icon {
            background: linear-gradient(135deg, #e74a3b 0%, #c0392b 100%);
        }

        .summary-card.bets .summary-icon {
            background: linear-gradient(135deg, #f6c23e 0%, #d4ac0d 100%);
        }

        .summary-card.wins .summary-icon {
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        }

        .summary-details {
            flex: 1;
        }

        .summary-label {
            display: block;
            font-size: 0.85rem;
            color: #999;
            margin-bottom: 5px;
        }

        .summary-value {
            display: block;
            font-size: 1.3rem;
            font-weight: 700;
            color: #333;
        }

        /* Rest of your existing styles */
        .transactions-container {
            padding: 40px 0;
            background: #f8f9fc;
            min-height: calc(100vh - 76px);
        }

        .transactions-header {
            margin-bottom: 30px;
        }

        .back-link {
            color: #667eea;
            text-decoration: none;
            font-size: 0.95rem;
            display: inline-block;
            margin-bottom: 15px;
            transition: all 0.3s ease;
        }

        .back-link:hover {
            transform: translateX(-5px);
            color: #764ba2;
        }

        .transactions-title {
            font-size: 2.2rem;
            font-weight: 700;
            color: #333;
            margin-bottom: 10px;
        }

        .transactions-subtitle {
            color: #666;
            font-size: 1.1rem;
        }

        .balance-summary {
            background: white;
            padding: 15px 25px;
            border-radius: 12px;
            display: inline-block;
            box-shadow: 0 5px 15px rgba(0, 0, 0, 0.05);
        }

        .balance-summary span {
            color: #666;
            margin-right: 10px;
        }

        .balance-summary strong {
            font-size: 1.3rem;
            color: #667eea;
        }

        .filters-card {
            background: white;
            border-radius: 15px;
            padding: 25px;
            margin-bottom: 30px;
            box-shadow: 0 5px 15px rgba(0, 0, 0, 0.05);
        }

        .filter-select {
            padding: 10px 15px;
            border: 2px solid #e0e0e0;
            border-radius: 10px;
            font-size: 0.95rem;
            transition: all 0.3s ease;
            background: #f8f9fc;
        }

        .filter-select:focus {
            border-color: #667eea;
            outline: none;
            box-shadow: 0 5px 15px rgba(102, 126, 234, 0.1);
        }

        .date-range {
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .date-range input {
            flex: 1;
            padding: 10px;
            border: 2px solid #e0e0e0;
            border-radius: 10px;
            font-size: 0.95rem;
        }

        .date-range span {
            color: #666;
            font-weight: 500;
        }

        .transactions-card {
            background: white;
            border-radius: 20px;
            padding: 30px;
            box-shadow: 0 10px 30px rgba(0, 0, 0, 0.1);
        }

        .transactions-list {
            display: flex;
            flex-direction: column;
            gap: 15px;
        }

        .transaction-item {
            display: flex;
            align-items: flex-start;
            padding: 20px;
            background: #f8f9fc;
            border-radius: 15px;
            transition: all 0.3s ease;
            border-left: 4px solid transparent;
        }

        .transaction-item:hover {
            transform: translateX(5px);
            background: #f0f2f5;
        }

        .transaction-item[data-type="deposit"] {
            border-left-color: #1cc88a;
        }

        .transaction-item[data-type="withdrawal"] {
            border-left-color: #e74a3b;
        }

        .transaction-item[data-type="bet"] {
            border-left-color: #f6c23e;
        }

        .transaction-item[data-type="win"] {
            border-left-color: #667eea;
        }

        .transaction-item[data-type="refund"] {
            border-left-color: #36b9cc;
        }

        .transaction-icon {
            width: 50px;
            height: 50px;
            border-radius: 12px;
            display: flex;
            align-items: center;
            justify-content: center;
            margin-right: 20px;
            color: white;
            font-size: 1.3rem;
            flex-shrink: 0;
        }

        .transaction-icon.deposit {
            background: linear-gradient(135deg, #1cc88a 0%, #17a673 100%);
        }

        .transaction-icon.withdrawal {
            background: linear-gradient(135deg, #e74a3b 0%, #c0392b 100%);
        }

        .transaction-icon.bet {
            background: linear-gradient(135deg, #f6c23e 0%, #d4ac0d 100%);
        }

        .transaction-icon.win {
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        }

        .transaction-icon.refund {
            background: linear-gradient(135deg, #36b9cc 0%, #258391 100%);
        }

        .transaction-details {
            flex: 1;
        }

        .transaction-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 8px;
        }

        .transaction-title {
            font-size: 1.1rem;
            font-weight: 600;
            color: #333;
            margin: 0;
        }

        .transaction-id {
            font-size: 0.85rem;
            color: #999;
            font-family: monospace;
        }

        .transaction-meta {
            display: flex;
            gap: 20px;
            margin-bottom: 8px;
            flex-wrap: wrap;
        }

        .transaction-date,
        .transaction-game {
            font-size: 0.9rem;
            color: #666;
        }

        .transaction-date i,
        .transaction-game i {
            margin-right: 5px;
            color: #999;
        }

        .transaction-payment {
            font-size: 0.85rem;
            color: #999;
        }

        .transaction-payment i {
            margin-right: 5px;
        }

        .transaction-amount-section {
            text-align: right;
            min-width: 150px;
        }

        .transaction-amount {
            font-size: 1.3rem;
            font-weight: 700;
            margin-bottom: 5px;
        }

        .transaction-amount.deposit,
        .transaction-amount.win,
        .transaction-amount.refund {
            color: #1cc88a;
        }

        .transaction-amount.withdrawal,
        .transaction-amount.bet {
            color: #e74a3b;
        }

        .transaction-balance {
            font-size: 0.9rem;
            color: #666;
            margin-bottom: 8px;
        }

        .transaction-status {
            text-align: right;
        }

        .status-badge {
            display: inline-block;
            padding: 4px 12px;
            border-radius: 50px;
            font-size: 0.8rem;
            font-weight: 500;
            text-transform: capitalize;
        }

        .status-badge.completed {
            background: rgba(28, 200, 138, 0.1);
            color: #1cc88a;
        }

        .status-badge.pending {
            background: rgba(246, 194, 62, 0.1);
            color: #f6c23e;
        }

        .status-badge.failed {
            background: rgba(231, 74, 59, 0.1);
            color: #e74a3b;
        }

        .empty-state {
            text-align: center;
            padding: 80px 20px;
        }

        .empty-state h3 {
            font-size: 1.5rem;
            font-weight: 600;
            color: #333;
            margin-bottom: 10px;
        }

        .pagination-nav {
            margin-top: 30px;
        }

        .pagination {
            justify-content: center;
        }

        .page-link {
            color: #667eea;
            border: none;
            padding: 10px 15px;
            margin: 0 5px;
            border-radius: 10px;
            transition: all 0.3s ease;
        }

        .page-link:hover {
            background: #667eea;
            color: white;
        }

        .page-item.active .page-link {
            background: #667eea;
            color: white;
        }

        .page-item.disabled .page-link {
            color: #ccc;
            pointer-events: none;
        }

        @media (max-width: 768px) {
            .summary-cards .col-md-3 {
                margin-bottom: 15px;
            }

            .transaction-item {
                flex-direction: column;
            }

            .transaction-icon {
                margin-bottom: 15px;
            }

            .transaction-amount-section {
                text-align: left;
                margin-top: 15px;
                margin-left: 70px;
            }

            .transaction-status {
                text-align: left;
            }

            .date-range {
                flex-direction: column;
            }

            .balance-summary {
                display: block;
                text-align: center;
                margin-top: 20px;
            }
        }
    </style>

    <script>
        // Add mongoose at the top of the controller if not already there
        const mongoose = require('mongoose');

        // Filter functionality
        document.getElementById('typeFilter')?.addEventListener('change', filterTransactions);
        document.getElementById('statusFilter')?.addEventListener('change', filterTransactions);
        document.getElementById('startDate')?.addEventListener('change', filterTransactions);
        document.getElementById('endDate')?.addEventListener('change', filterTransactions);

        function filterTransactions() {
            const typeFilter = document.getElementById('typeFilter').value;
            const statusFilter = document.getElementById('statusFilter').value;
            const startDate = document.getElementById('startDate').value;
            const endDate = document.getElementById('endDate').value;

            const transactions = document.querySelectorAll('.transaction-item');

            transactions.forEach(transaction => {
                let show = true;

                if (typeFilter !== 'all' && transaction.dataset.type !== typeFilter) {
                    show = false;
                }

                if (statusFilter !== 'all' && transaction.dataset.status !== statusFilter) {
                    show = false;
                }

                if (startDate && transaction.dataset.date < startDate) {
                    show = false;
                }

                if (endDate && transaction.dataset.date > endDate) {
                    show = false;
                }

                transaction.style.display = show ? 'flex' : 'none';
            });
        }
    </script>

    <%- include('../partials/footer') %>