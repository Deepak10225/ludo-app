<%- include('../partials/header') %>

<div class="withdraw-container" style="min-height: 100vh; padding: 100px 0; position: relative;">
    <div class="hero-bg"></div>
    <div class="container">
        <!-- Header -->
        <div class="row align-items-center mb-5" data-aos="fade-down">
            <div class="col-md-7">
                <a href="/wallet" class="btn btn-outline-light rounded-pill mb-3">
                    <i class="fas fa-arrow-left me-2"></i> Back to Wallet
                </a>
                <h1 class="fw-bold text-white mb-2">
                    <i class="fas fa-arrow-up text-gradient me-2"></i> Withdraw Funds
                </h1>
                <p class="text-white-50 fs-5 mb-0">Transfer your winnings securely to your bank</p>
            </div>
            <div class="col-md-5 text-md-end mt-4 mt-md-0">
                <div class="glass-card p-3 rounded-pill d-inline-flex align-items-center border-success border border-opacity-50">
                    <span class="text-white-50 me-3">Withdrawable Balance</span>
                    <span class="fs-4 fw-bold text-success">₹<%= user.walletBalance.toLocaleString('en-IN', {minimumFractionDigits: 2, maximumFractionDigits: 2}) %></span>
                </div>
            </div>
        </div>

        <div class="row justify-content-center">
            <div class="col-lg-8 col-xl-7">
                <!-- Withdraw Form Card -->
                <div class="glass-card p-4 p-md-5 mb-5 shadow-lg position-relative overflow-hidden" data-aos="fade-up">
                    <div class="position-absolute top-0 start-0 w-100 h-1 px-0" style="background: linear-gradient(90deg, #1cc88a, #f6c23e); height: 4px;"></div>
                    
                    <form action="/wallet/withdraw" method="POST" id="withdrawForm">
                        <!-- Amount Section -->
                        <div class="mb-5">
                            <label class="form-label text-white-50 text-uppercase tracking-wider small fw-bold mb-3 d-flex justify-content-between align-items-center">
                                <span>Withdrawal Amount</span>
                                <button type="button" class="btn btn-sm btn-outline-success rounded-pill px-3 py-1" onclick="setAmount(<%= user.walletBalance %>)">Max</button>
                            </label>
                            <div class="input-group">
                                <span class="input-group-text bg-dark text-white border-0 px-4 fs-3 border-end-0 shadow-none" style="background-color: rgba(0,0,0,0.4) !important;">₹</span>
                                <input type="number" class="form-control form-control-lg bg-dark text-white border-0 fs-2 fw-bold shadow-none" id="amount" name="amount" min="100" max="<%= user.walletBalance %>" step="1" required placeholder="0" style="background-color: rgba(0,0,0,0.4) !important;">
                            </div>
                            
                            <div class="d-flex justify-content-between mt-3 text-white-50 small">
                                <div><i class="fas fa-info-circle me-1"></i> Min: ₹100 | Max: ₹<%= Math.min(user.walletBalance, 100000).toLocaleString('en-IN') %></div>
                                <div id="amountWarning" class="text-danger d-none"><i class="fas fa-exclamation-triangle me-1"></i> Insufficient balance</div>
                            </div>
                        </div>

                        <!-- Withdrawal Method Selection -->
                        <div class="mb-5">
                            <label class="form-label text-white-50 text-uppercase tracking-wider small fw-bold mb-3">Select Transfer Method</label>
                            
                            <div class="row g-3">
                                <!-- UPI Option -->
                                <div class="col-md-6">
                                    <input class="btn-check" type="radio" name="withdrawalMethod" id="methodUPI" value="upi" checked>
                                    <label class="btn btn-outline-light w-100 h-100 text-start p-4 rounded-4 method-card border-white-10" for="methodUPI">
                                        <div class="d-flex align-items-center mb-2">
                                            <div class="bg-primary bg-gradient rounded-circle d-flex align-items-center justify-content-center me-3" style="width: 40px; height: 40px;">
                                                <i class="fas fa-mobile-alt text-white"></i>
                                            </div>
                                            <h5 class="mb-0 fw-bold">UPI Transfer</h5>
                                            <i class="fas fa-check-circle text-success ms-auto selected-icon opacity-0 fs-4"></i>
                                        </div>
                                        <p class="text-white-50 small mb-0 ms-5 ps-1">Instant via GPay, PhonePe, Paytm</p>
                                    </label>
                                </div>
                                
                                <!-- Bank Transfer Option -->
                                <div class="col-md-6">
                                    <input class="btn-check" type="radio" name="withdrawalMethod" id="methodBank" value="bank">
                                    <label class="btn btn-outline-light w-100 h-100 text-start p-4 rounded-4 method-card border-white-10" for="methodBank">
                                        <div class="d-flex align-items-center mb-2">
                                            <div class="bg-info bg-gradient rounded-circle d-flex align-items-center justify-content-center me-3" style="width: 40px; height: 40px;">
                                                <i class="fas fa-university text-white"></i>
                                            </div>
                                            <h5 class="mb-0 fw-bold">Bank Transfer</h5>
                                            <i class="fas fa-check-circle text-success ms-auto selected-icon opacity-0 fs-4"></i>
                                        </div>
                                        <p class="text-white-50 small mb-0 ms-5 ps-1">IMPS/NEFT (Takes 2-4 hours)</p>
                                    </label>
                                </div>
                            </div>
                        </div>

                        <!-- Details Forms -->
                        <div class="bg-dark bg-opacity-25 rounded-4 p-4 mb-5 border border-white-10 shadow-inner">
                            <!-- UPI Details -->
                            <div id="upiDetails">
                                <label for="upiId" class="form-label text-white-50 fw-bold">Enter UPI ID</label>
                                <div class="input-group">
                                    <span class="input-group-text bg-dark border-white-20 text-white border-end-0"><i class="fas fa-at"></i></span>
                                    <input type="text" class="form-control bg-dark text-white border-white-20 border-start-0 shadow-none py-3" id="upiId" name="upiId" placeholder="example@upi" required>
                                </div>
                                <div class="form-text text-white-50 mt-2">Make sure the UPI ID is correct. Funds sent to wrong UPI IDs cannot be recovered.</div>
                            </div>

                            <!-- Bank Details (Initially Hidden) -->
                            <div id="bankDetails" class="d-none">
                                <div class="mb-3">
                                    <label for="accountName" class="form-label text-white-50 fw-bold">Account Holder Name</label>
                                    <input type="text" class="form-control bg-dark text-white border-white-20 shadow-none py-3" id="accountName" name="accountName" placeholder="Name as per bank">
                                </div>
                                <div class="mb-3">
                                    <label for="accountNumber" class="form-label text-white-50 fw-bold">Account Number</label>
                                    <input type="text" class="form-control bg-dark text-white border-white-20 shadow-none py-3" id="accountNumber" name="accountNumber" placeholder="Double check account number">
                                </div>
                                <div>
                                    <label for="ifscCode" class="form-label text-white-50 fw-bold">IFSC Code</label>
                                    <input type="text" class="form-control bg-dark text-white border-white-20 shadow-none py-3 text-uppercase" id="ifscCode" name="ifscCode" placeholder="e.g. SBIN0001234">
                                </div>
                            </div>
                        </div>

                        <!-- Summary & Submit -->
                        <div class="row align-items-center bg-dark bg-opacity-50 p-4 rounded-4 border border-white-10 mb-4">
                            <div class="col-8">
                                <span class="text-white-50 small d-block mb-1">Fee (0%)</span>
                                <span class="text-white fw-bold fs-5">You receive: <span id="receiveAmount" class="text-success">₹0.00</span></span>
                            </div>
                            <div class="col-4 text-end">
                                <i class="fas fa-shield-check text-success fs-3"></i>
                            </div>
                        </div>

                        <button type="submit" class="btn btn-success btn-lg w-100 rounded-pill hover-lift shadow-lg py-3 fw-bold fs-5" id="submitBtn" disabled>
                            <i class="fas fa-paper-plane me-2"></i> Confirm Withdrawal
                        </button>
                    </form>
                </div>

                <!-- Info Cards -->
                <div class="row g-4" data-aos="fade-up" data-aos-delay="100">
                    <div class="col-md-6">
                        <div class="glass-card p-4 h-100 border-white-10 d-flex gap-3">
                            <i class="fas fa-clock text-warning fs-3 mt-1"></i>
                            <div>
                                <h6 class="text-white fw-bold mb-2">Processing Time</h6>
                                <p class="text-white-50 small mb-0">UPI transfers are usually instant. Bank transfers may take 2-4 hours during business days.</p>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="glass-card p-4 h-100 border-white-10 d-flex gap-3">
                            <i class="fas fa-headset text-info fs-3 mt-1"></i>
                            <div>
                                <h6 class="text-white fw-bold mb-2">Need Help?</h6>
                                <p class="text-white-50 small mb-0">If your funds don't arrive within 24 hours, contact our 24/7 support using transaction ID.</p>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .tracking-wider { letter-spacing: 0.05em; }
    .border-white-10 { border-color: rgba(255, 255, 255, 0.1) !important; }
    .border-white-20 { border-color: rgba(255, 255, 255, 0.2) !important; }
    
    .hover-lift { transition: transform 0.2s ease, box-shadow 0.2s ease; }
    .hover-lift:hover:not(:disabled) { transform: translateY(-5px); box-shadow: 0 10px 25px rgba(28, 200, 138, 0.3) !important; }
    
    .shadow-inner { box-shadow: inset 0 2px 10px rgba(0,0,0,0.5); }

    /* Custom Radio Button Styling */
    .btn-check:checked + .method-card {
        background: rgba(255, 255, 255, 0.05);
        border-color: var(--bs-primary) !important;
        box-shadow: 0 0 0 1px var(--bs-primary);
    }
    
    .btn-check:focus + .method-card {
        box-shadow: 0 0 0 0.25rem rgba(102, 126, 234, 0.25);
    }

    .btn-check:checked + .method-card .selected-icon {
        opacity: 1 !important;
    }

    input::-webkit-outer-spin-button,
    input::-webkit-inner-spin-button {
        -webkit-appearance: none;
        margin: 0;
    }
    input[type=number] {
        -moz-appearance: textfield;
    }
</style>

<script>
    document.addEventListener('DOMContentLoaded', function() {
        const amountInput = document.getElementById('amount');
        const submitBtn = document.getElementById('submitBtn');
        const receiveAmount = document.getElementById('receiveAmount');
        const amountWarning = document.getElementById('amountWarning');
        const userBalance = <%= user.walletBalance %>;
        
        const methodUPI = document.getElementById('methodUPI');
        const methodBank = document.getElementById('methodBank');
        const upiDetails = document.getElementById('upiDetails');
        const bankDetails = document.getElementById('bankDetails');
        const upiIdStr = document.getElementById('upiId');
        const accName = document.getElementById('accountName');
        const accNum = document.getElementById('accountNumber');
        const ifsc = document.getElementById('ifscCode');

        // Toggle Details based on Method Selection
        function toggleMethod() {
            if (methodUPI.checked) {
                upiDetails.classList.remove('d-none');
                bankDetails.classList.add('d-none');
                upiIdStr.required = true;
                accName.required = false;
                accNum.required = false;
                ifsc.required = false;
            } else {
                upiDetails.classList.add('d-none');
                bankDetails.classList.remove('d-none');
                upiIdStr.required = false;
                accName.required = true;
                accNum.required = true;
                ifsc.required = true;
            }
            validateForm();
        }

        methodUPI.addEventListener('change', toggleMethod);
        methodBank.addEventListener('change', toggleMethod);

        // Validate Amount and Required Fields
        function validateForm() {
            const amount = parseFloat(amountInput.value) || 0;
            receiveAmount.textContent = amount > 0 ? '₹' + amount.toLocaleString('en-IN', {minimumFractionDigits: 2}) : '₹0.00';
            
            let isValid = true;

            if (amount < 100) {
                isValid = false;
                amountWarning.classList.add('d-none');
            } else if (amount > userBalance) {
                isValid = false;
                amountWarning.classList.remove('d-none');
            } else {
                amountWarning.classList.add('d-none');
            }
            
            // Allow basic HTML5 validation to handle empty required fields when clicking submit
            // We just disable button if amount is invalid
            submitBtn.disabled = !isValid;
        }

        amountInput.addEventListener('input', validateForm);

        // Optional: form submission event listener for additional frontend validation before sending
        document.getElementById('withdrawForm').addEventListener('submit', function(e) {
            const amount = parseFloat(amountInput.value) || 0;
            if (amount < 100 || amount > userBalance) {
                e.preventDefault();
                alert('Invalid withdrawal amount.');
                return;
            }
            
            // Show loading state
            submitBtn.innerHTML = '<span class="spinner-border spinner-border-sm me-2" role="status" aria-hidden="true"></span> Processing...';
            submitBtn.disabled = true;
        });
    });

    // Helper function for Max button
    function setAmount(val) {
        document.getElementById('amount').value = Math.floor(val); // Ensure whole number
        // trigger input event to recalculate validation
        document.getElementById('amount').dispatchEvent(new Event('input'));
    }
</script>

<%- include('../partials/footer') %>