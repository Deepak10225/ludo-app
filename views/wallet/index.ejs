<%- include('../partials/header') %>

<div class="wallet-container" style="min-height: 100vh; padding: 100px 0; position: relative;">
    <div class="hero-bg"></div>
    <div class="container">
        <!-- Wallet Header -->
        <div class="row align-items-center mb-5" data-aos="fade-down">
            <div class="col-md-8">
                <h1 class="fw-bold text-white mb-2">
                    <i class="fas fa-wallet text-gradient me-2"></i> My Wallet
                </h1>
                <p class="text-white-50 fs-5 mb-0">Manage your funds and transactions securely</p>
            </div>
            <div class="col-md-4 text-md-end mt-4 mt-md-0 d-flex justify-content-md-end gap-3">
                <button class="btn btn-primary rounded-pill px-4 hover-lift" onclick="showDepositModal()">
                    <i class="fas fa-plus-circle me-2"></i> Add Money
                </button>
                <a href="/wallet/withdraw" class="btn btn-outline-light rounded-pill px-4 hover-lift">
                    <i class="fas fa-arrow-up me-2"></i> Withdraw
                </a>
            </div>
        </div>

        <!-- Balance Card -->
        <div class="glass-card mb-5 p-5 position-relative overflow-hidden shadow-lg border-0" style="background: linear-gradient(135deg, rgba(102, 126, 234, 0.2) 0%, rgba(118, 75, 162, 0.2) 100%);" data-aos="fade-up">
            <div class="position-absolute top-0 end-0 p-4 opacity-10">
                <i class="fas fa-wallet fa-10x"></i>
            </div>
            <div class="row align-items-center position-relative z-1">
                <div class="col-md-6 mb-4 mb-md-0">
                    <div class="text-white-50 text-uppercase tracking-wider small mb-2">Available Balance</div>
                    <div class="display-3 fw-bold text-white mb-2 text-gradient">
                        ₹<%= user.walletBalance.toLocaleString('en-IN', {minimumFractionDigits: 2, maximumFractionDigits: 2}) %>
                    </div>
                    <div class="badge bg-success bg-opacity-25 text-success border border-success px-3 py-2 rounded-pill">
                        <i class="fas fa-bolt me-1"></i> Instant withdrawals available
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="bg-dark bg-opacity-25 border border-white-10 rounded-4 p-4 backdrop-blur">
                        <div class="row g-4 text-center">
                            <div class="col-4">
                                <div class="fs-3 fw-bold text-white mb-1"><%= user.totalGames || 0 %></div>
                                <div class="text-white-50 small">Total Games</div>
                            </div>
                            <div class="col-4 border-start border-white-10">
                                <div class="fs-3 fw-bold text-warning mb-1"><%= user.totalWins || 0 %></div>
                                <div class="text-white-50 small">Wins</div>
                            </div>
                            <div class="col-4 border-start border-white-10">
                                <div class="fs-4 fw-bold text-success mb-1">₹<%= (user.totalEarnings || 0).toLocaleString('en-IN', { maximumFractionDigits: 0 }) %></div>
                                <div class="text-white-50 small">Earnings</div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Quick Actions -->
        <div class="mb-5" data-aos="fade-up" data-aos-delay="100">
            <div class="d-flex align-items-center mb-4">
                <i class="fas fa-bolt text-warning fs-4 me-3"></i>
                <h3 class="text-white fw-bold mb-0">Quick Actions</h3>
            </div>

            <div class="row g-4">
                <!-- Add Money -->
                <div class="col-md-4">
                    <div class="glass-card p-4 h-100 hover-lift cursor-pointer" onclick="showDepositModal()">
                        <div class="d-flex align-items-center gap-3">
                            <div class="bg-primary bg-gradient rounded-circle d-flex align-items-center justify-content-center flex-shrink-0 shadow" style="width: 60px; height: 60px; font-size: 1.5rem;">
                                <i class="fas fa-plus text-white"></i>
                            </div>
                            <div>
                                <h5 class="text-white fw-bold mb-1">Add Money</h5>
                                <p class="text-white-50 small mb-0">Deposit to your wallet</p>
                            </div>
                            <div class="ms-auto text-white-50">
                                <i class="fas fa-chevron-right"></i>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Withdraw -->
                <div class="col-md-4">
                    <a href="/wallet/withdraw" class="text-decoration-none">
                        <div class="glass-card p-4 h-100 hover-lift cursor-pointer border-success border border-opacity-25">
                            <div class="d-flex align-items-center gap-3">
                                <div class="bg-success bg-gradient rounded-circle d-flex align-items-center justify-content-center flex-shrink-0 shadow" style="width: 60px; height: 60px; font-size: 1.5rem;">
                                    <i class="fas fa-arrow-up text-white"></i>
                                </div>
                                <div>
                                    <h5 class="text-white fw-bold mb-1">Withdraw</h5>
                                    <p class="text-white-50 small mb-0">Transfer to bank/UPI</p>
                                </div>
                                <div class="ms-auto text-white-50">
                                    <i class="fas fa-chevron-right"></i>
                                </div>
                            </div>
                        </div>
                    </a>
                </div>

                <!-- History -->
                <div class="col-md-4">
                    <a href="/wallet/transactions" class="text-decoration-none">
                        <div class="glass-card p-4 h-100 hover-lift cursor-pointer">
                            <div class="d-flex align-items-center gap-3">
                                <div class="bg-info bg-gradient rounded-circle d-flex align-items-center justify-content-center flex-shrink-0 shadow" style="width: 60px; height: 60px; font-size: 1.5rem;">
                                    <i class="fas fa-history text-white"></i>
                                </div>
                                <div>
                                    <h5 class="text-white fw-bold mb-1">History</h5>
                                    <p class="text-white-50 small mb-0">View all transactions</p>
                                </div>
                                <div class="ms-auto text-white-50">
                                    <i class="fas fa-chevron-right"></i>
                                </div>
                            </div>
                        </div>
                    </a>
                </div>

                <!-- Refer -->
                <div class="col-md-6">
                    <div class="glass-card p-4 h-100 hover-lift cursor-pointer" onclick="showReferModal()">
                        <div class="d-flex align-items-center gap-3">
                            <div class="bg-danger bg-gradient rounded-circle d-flex align-items-center justify-content-center flex-shrink-0 shadow" style="width: 60px; height: 60px; font-size: 1.5rem;">
                                <i class="fas fa-gift text-white"></i>
                            </div>
                            <div>
                                <h5 class="text-white fw-bold mb-1">Refer & Earn</h5>
                                <p class="text-white-50 small mb-0">Get ₹100 for each friend</p>
                            </div>
                            <div class="ms-auto text-white-50">
                                <i class="fas fa-chevron-right"></i>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Support -->
                <div class="col-md-6">
                    <div class="glass-card p-4 h-100 hover-lift cursor-pointer" onclick="showSupportModal()">
                        <div class="d-flex align-items-center gap-3">
                            <div class="bg-secondary bg-gradient rounded-circle d-flex align-items-center justify-content-center flex-shrink-0 shadow" style="width: 60px; height: 60px; font-size: 1.5rem;">
                                <i class="fas fa-headset text-white"></i>
                            </div>
                            <div>
                                <h5 class="text-white fw-bold mb-1">24/7 Support</h5>
                                <p class="text-white-50 small mb-0">Get help with payments</p>
                            </div>
                            <div class="ms-auto text-white-50">
                                <i class="fas fa-chevron-right"></i>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Recent Transactions -->
        <div class="glass-card p-4 p-md-5 mb-5 border-white-10" data-aos="fade-up" data-aos-delay="200">
            <div class="d-flex justify-content-between align-items-center mb-4 border-bottom border-white-10 pb-3">
                <h3 class="text-white fw-bold mb-0"><i class="fas fa-exchange-alt text-primary me-2"></i> Recent Transactions</h3>
                <a href="/wallet/transactions" class="btn btn-outline-light btn-sm rounded-pill px-3">View All</a>
            </div>

            <% if (recentTransactions && recentTransactions.length > 0) { %>
                <div class="d-flex flex-column gap-3">
                    <% recentTransactions.forEach(transaction => { %>
                        <div class="bg-dark bg-opacity-50 rounded-4 p-3 border border-white-10 d-flex align-items-center hover-lift">
                            <!-- Icon -->
                            <div class="rounded-circle d-flex align-items-center justify-content-center flex-shrink-0 me-3 shadow" style="width: 50px; height: 50px; font-size: 1.2rem;
                                <%= transaction.type === 'deposit' ? 'background: linear-gradient(135deg, #1cc88a 0%, #17a673 100%); color: white;' : '' %>
                                <%= transaction.type === 'withdrawal' ? 'background: linear-gradient(135deg, #e74a3b 0%, #c0392b 100%); color: white;' : '' %>
                                <%= transaction.type === 'bet' ? 'background: linear-gradient(135deg, #f6c23e 0%, #d4ac0d 100%); color: #333;' : '' %>
                                <%= transaction.type === 'win' ? 'background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); color: white;' : '' %>
                                <%= !['deposit', 'withdrawal', 'bet', 'win'].includes(transaction.type) ? 'background: linear-gradient(135deg, #858796 0%, #60616f 100%); color: white;' : '' %>
                            ">
                                <% if (transaction.type === 'deposit') { %><i class="fas fa-arrow-down"></i><% } %>
                                <% if (transaction.type === 'withdrawal') { %><i class="fas fa-arrow-up"></i><% } %>
                                <% if (transaction.type === 'bet') { %><i class="fas fa-gamepad"></i><% } %>
                                <% if (transaction.type === 'win') { %><i class="fas fa-trophy"></i><% } %>
                                <% if (!['deposit', 'withdrawal', 'bet', 'win'].includes(transaction.type)) { %><i class="fas fa-exchange-alt"></i><% } %>
                            </div>

                            <!-- Details -->
                            <div class="flex-grow-1">
                                <h6 class="text-white fw-bold mb-1">
                                    <%= transaction.description || transaction.type.charAt(0).toUpperCase() + transaction.type.slice(1) %>
                                </h6>
                                <div class="text-white-50 small">
                                    <%= new Date(transaction.createdAt).toLocaleDateString('en-IN', { day: 'numeric', month: 'short', hour: '2-digit', minute: '2-digit' }) %>
                                </div>
                            </div>

                            <!-- Amount & Status -->
                            <div class="text-end">
                                <div class="fw-bold fs-5 mb-1 <%= (transaction.type === 'withdrawal' || transaction.type === 'bet') ? 'text-danger' : 'text-success' %>">
                                    <%= (transaction.type === 'withdrawal' || transaction.type === 'bet') ? '-' : '+' %>₹<%= transaction.amount.toLocaleString(undefined, {minimumFractionDigits: 2, maximumFractionDigits: 2}) %>
                                </div>
                                <div>
                                    <span class="badge rounded-pill
                                        <%= transaction.status === 'completed' ? 'bg-success bg-opacity-25 text-success border border-success' : '' %>
                                        <%= transaction.status === 'pending' ? 'bg-warning bg-opacity-25 text-warning border border-warning' : '' %>
                                        <%= transaction.status === 'failed' ? 'bg-danger bg-opacity-25 text-danger border border-danger' : '' %>
                                    ">
                                        <%= transaction.status.charAt(0).toUpperCase() + transaction.status.slice(1) %>
                                    </span>
                                </div>
                            </div>
                        </div>
                    <% }) %>
                </div>
            <% } else { %>
                <div class="text-center py-5">
                    <div class="bg-dark bg-opacity-50 rounded-circle d-inline-flex align-items-center justify-content-center mb-4 border border-white-10" style="width: 100px; height: 100px;">
                        <i class="fas fa-receipt fa-3x text-white-50"></i>
                    </div>
                    <h4 class="text-white fw-bold mb-2">No Transactions Yet</h4>
                    <p class="text-white-50 mb-4">Your transaction history will appear here once you make your first deposit or play a game.</p>
                    <button class="btn btn-primary rounded-pill px-4 hover-lift" onclick="showDepositModal()">
                        <i class="fas fa-plus me-2"></i> Make First Deposit
                    </button>
                </div>
            <% } %>
        </div>
    </div>
</div>

<!-- Deposit Modal -->
<div class="modal fade" id="depositModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content glass-card border-0 shadow-lg position-relative overflow-hidden">
            <div class="position-absolute top-0 start-0 w-100 h-1 px-0" style="background: linear-gradient(90deg, var(--bs-primary), var(--bs-info)); height: 4px;"></div>
            <div class="modal-header border-bottom border-white-10 pb-3">
                <h5 class="modal-title text-white fw-bold"><i class="fas fa-plus-circle text-primary me-2"></i> Add Funds</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body p-4">
                <form action="/wallet/deposit" method="POST" id="depositForm">
                    <!-- Presets -->
                    <div class="row g-2 mb-4">
                        <div class="col-3"><button type="button" class="btn btn-outline-primary w-100 rounded-pill fs-6 py-2" onclick="setAmount(100)">₹100</button></div>
                        <div class="col-3"><button type="button" class="btn btn-outline-primary w-100 rounded-pill fs-6 py-2" onclick="setAmount(500)">₹500</button></div>
                        <div class="col-3"><button type="button" class="btn btn-outline-primary w-100 rounded-pill fs-6 py-2" onclick="setAmount(1000)">₹1K</button></div>
                        <div class="col-3"><button type="button" class="btn btn-outline-primary w-100 rounded-pill fs-6 py-2" onclick="setAmount(5000)">₹5K</button></div>
                    </div>

                    <div class="mb-4">
                        <label class="form-label text-white-50 small text-uppercase tracking-wider">Enter Amount</label>
                        <div class="input-group">
                            <span class="input-group-text bg-dark border-white-20 text-white border-end-0 px-4 fs-4 border-end-0">₹</span>
                            <input type="number" class="form-control form-control-lg bg-dark text-white border-white-20 border-start-0 fs-4 fw-bold shadow-none" id="amount" name="amount" min="100" step="1" required placeholder="0">
                        </div>
                        <div class="form-text text-white-50 mt-2"><i class="fas fa-info-circle me-1"></i> Minimum deposit: ₹100</div>
                    </div>

                    <div class="mb-4">
                        <label class="form-label text-white-50 small text-uppercase tracking-wider">Payment Method</label>
                        <select class="form-select bg-dark text-white border-white-20 py-3 appearance-none custom-select" id="paymentMethod" name="paymentMethod" required>
                            <option value="">Select a method...</option>
                            <option value="razorpay">Razorpay (UPI / Cards / NetBanking)</option>
                            <option value="paytm">Paytm Wallet</option>
                            <option value="phonepe">PhonePe UPI</option>
                        </select>
                    </div>

                    <button type="submit" class="btn btn-primary btn-lg w-100 rounded-pill hover-lift shadow mb-3">
                        <i class="fas fa-lock me-2"></i> Proceed to Pay securely
                    </button>
                    
                    <div class="text-center text-white-50 small">
                        <i class="fas fa-shield-alt text-success me-1"></i> 100% Safe & Secure Payments
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

<!-- Refer Modal -->
<div class="modal fade" id="referModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content glass-card border-0 shadow-lg">
            <div class="modal-header border-bottom border-white-10">
                <h5 class="modal-title text-white fw-bold"><i class="fas fa-gift text-danger me-2"></i> Refer & Earn</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body text-center p-5">
                <div class="bg-danger bg-opacity-25 rounded-circle d-inline-flex align-items-center justify-content-center mb-4 border border-danger border-opacity-50 pulse-animation" style="width: 100px; height: 100px;">
                    <i class="fas fa-gift fa-3x text-danger"></i>
                </div>
                <h3 class="text-white fw-bold mb-3">Earn <span class="text-gradient">₹100</span> per friend!</h3>
                <p class="text-white-50 mb-4">Share your referral code. When your friend signs up and makes their first deposit, you both get ₹100!</p>

                <div class="bg-dark bg-opacity-50 p-4 rounded-4 border border-white-10 mb-4">
                    <div class="text-white-50 small mb-2 text-uppercase tracking-wider">Your Referral Code</div>
                    <div class="d-flex align-items-center justify-content-center gap-3">
                        <h2 class="font-monospace fw-bold text-white mb-0 tracking-wide" id="refCodeText">
                            <%= user.referralCode || 'LUDO' + (user._id ? user._id.toString().slice(-6).toUpperCase() : 'WINS' ) %>
                        </h2>
                        <button class="btn btn-outline-primary btn-sm rounded-pill" onclick="copyReferralCode()">
                            <i class="fas fa-copy"></i>
                        </button>
                    </div>
                </div>

                <div class="d-flex justify-content-center gap-3">
                    <button class="btn btn-outline-light rounded-pill px-4 hover-lift" style="border-color: #25D366; color: #25D366;" onclick="shareWhatsApp()">
                        <i class="fab fa-whatsapp me-2"></i> Share
                    </button>
                    <button class="btn btn-outline-light rounded-pill px-4 hover-lift" style="border-color: #0088cc; color: #0088cc;" onclick="shareTelegram()">
                        <i class="fab fa-telegram me-2"></i> Share
                    </button>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Support Modal -->
<div class="modal fade" id="supportModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content glass-card border-0 shadow-lg">
            <div class="modal-header border-bottom border-white-10">
                <h5 class="modal-title text-white fw-bold"><i class="fas fa-headset text-secondary me-2"></i> 24/7 Support</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body p-4">
                <div class="row g-3">
                    <div class="col-6">
                        <div class="bg-dark bg-opacity-50 p-3 rounded-4 border border-white-10 text-center hover-lift cursor-pointer h-100">
                            <i class="fab fa-whatsapp fa-2x text-success mb-2"></i>
                            <h6 class="text-white fw-bold">WhatsApp</h6>
                            <div class="text-white-50 small">Quickest reply</div>
                        </div>
                    </div>
                    <div class="col-6">
                        <div class="bg-dark bg-opacity-50 p-3 rounded-4 border border-white-10 text-center hover-lift cursor-pointer h-100 text-decoration-none text-reset" onclick="window.location.href='mailto:support@ludoplatform.com'">
                            <i class="fas fa-envelope fa-2x text-primary mb-2"></i>
                            <h6 class="text-white fw-bold">Email</h6>
                            <div class="text-white-50 small">Usually 24 hrs</div>
                        </div>
                    </div>
                </div>

                <div class="mt-4 pt-4 border-top border-white-10">
                    <h6 class="text-white fw-bold mb-3">Popular FAQs</h6>
                    <div class="accordion accordion-flush bg-transparent" id="faqAccordion">
                        <div class="accordion-item bg-transparent border-white-10 mb-2">
                            <h2 class="accordion-header">
                                <button class="accordion-button collapsed bg-dark bg-opacity-50 text-white rounded shadow-none" type="button" data-bs-toggle="collapse" data-bs-target="#faq1">
                                    Why is my deposit pending?
                                </button>
                            </h2>
                            <div id="faq1" class="accordion-collapse collapse" data-bs-parent="#faqAccordion">
                                <div class="accordion-body text-white-50 small bg-dark bg-opacity-25 rounded-bottom border border-top-0 border-white-10">
                                    Sometimes bank servers are slow. Give it 5-10 minutes. If money is deducted but not added, contact support.
                                </div>
                            </div>
                        </div>
                        <div class="accordion-item bg-transparent border-white-10">
                            <h2 class="accordion-header">
                                <button class="accordion-button collapsed bg-dark bg-opacity-50 text-white rounded shadow-none" type="button" data-bs-toggle="collapse" data-bs-target="#faq2">
                                    When will I receive my withdrawal?
                                </button>
                            </h2>
                            <div id="faq2" class="accordion-collapse collapse" data-bs-parent="#faqAccordion">
                                <div class="accordion-body text-white-50 small bg-dark bg-opacity-25 rounded-bottom border border-top-0 border-white-10">
                                    We use IMPS/NEFT. It usually takes less than 2 hours, but can take up to 24 hours depending on banking hours.
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .tracking-wider { letter-spacing: 0.05em; }
    .tracking-wide { letter-spacing: 0.1em; }
    .backdrop-blur { backdrop-filter: blur(10px); }
    .border-white-10 { border-color: rgba(255, 255, 255, 0.1) !important; }
    .border-white-20 { border-color: rgba(255, 255, 255, 0.2) !important; }
    .cursor-pointer { cursor: pointer; }
    
    .custom-select {
        background-image: url("data:image/svg+xml,%3csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 16 16'%3e%3cpath fill='none' stroke='%23ffffff' stroke-linecap='round' stroke-linejoin='round' stroke-width='2' d='m2 5 6 6 6-6'/%3e%3c/svg%3e");
        background-repeat: no-repeat;
        background-position: right 1rem center;
        background-size: 16px 12px;
    }

    .hover-lift { transition: transform 0.2s ease, box-shadow 0.2s ease; }
    .hover-lift:hover { transform: translateY(-5px); box-shadow: 0 10px 25px rgba(0,0,0,0.3) !important; }
    
    .pulse-animation { animation: pulse 2s infinite; }
    @keyframes pulse {
        0% { transform: scale(1); box-shadow: 0 0 0 0 rgba(220, 53, 69, 0.4); }
        70% { transform: scale(1.05); box-shadow: 0 0 0 15px rgba(220, 53, 69, 0); }
        100% { transform: scale(1); box-shadow: 0 0 0 0 rgba(220, 53, 69, 0); }
    }
    
    /* Override bootstrap accordion styles for dark theme */
    .accordion-button::after {
        filter: invert(1);
    }
</style>

<script>
    function showDepositModal() {
        var modal = new bootstrap.Modal(document.getElementById('depositModal'));
        modal.show();
    }

    function showReferModal() {
        var modal = new bootstrap.Modal(document.getElementById('referModal'));
        modal.show();
    }

    function showSupportModal() {
        var modal = new bootstrap.Modal(document.getElementById('supportModal'));
        modal.show();
    }

    function setAmount(val) {
        document.getElementById('amount').value = val;
    }

    function copyReferralCode() {
        var code = document.getElementById('refCodeText').innerText.trim();
        navigator.clipboard.writeText(code).then(function() {
            Swal.fire({
                icon: 'success',
                toast: true,
                position: 'top-end',
                showConfirmButton: false,
                timer: 3000,
                title: 'Referral Code Copied!',
                background: 'var(--bg-nav)',
                color: 'var(--text-main)'
            });
        });
    }

    function shareWhatsApp() {
        var code = document.getElementById('refCodeText').innerText.trim();
        var text = encodeURIComponent('Play Ludo and win real money! Use my referral code: ' + code + ' to get ₹100 bonus on your first deposit. Play now!');
        window.open('https://api.whatsapp.com/send?text=' + text);
    }
    
    function shareTelegram() {
        var code = document.getElementById('refCodeText').innerText.trim();
        var text = encodeURIComponent('Play Ludo and win real money! Use my referral code: ' + code + ' to get ₹100 bonus on your first deposit.');
        window.open('https://t.me/share/url?url=' + encodeURIComponent(window.location.origin) + '&text=' + text);
    }
</script>

<%- include('../partials/footer') %>