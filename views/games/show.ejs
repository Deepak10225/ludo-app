<%- include('../partials/header') %>

<div class="game-show-container" style="min-height: 100vh; padding: 100px 0; position: relative;">
    <div class="hero-bg"></div>
    <div class="container">
        <!-- Header -->
        <div class="row align-items-center mb-5" data-aos="fade-down">
            <div class="col-md-8">
                <a href="/games" class="btn btn-outline-light rounded-pill mb-3">
                    <i class="fas fa-arrow-left me-2"></i> Back to Games
                </a>
                <h1 class="fw-bold text-white mb-2">
                    <i class="fas fa-dice text-gradient me-2"></i> Game Details
                </h1>
                <p class="text-white-50 fs-5 d-flex align-items-center mb-0">
                    Room ID: <span class="badge bg-primary fs-6 ms-2 font-monospace" style="letter-spacing: 0.1em;"><%= game.roomId %></span>
                </p>
            </div>
            <div class="col-md-4 text-md-end mt-3 mt-md-0">
                <span class="badge rounded-pill border px-4 py-2 fs-6
                    <%= game.status === 'active' ? 'bg-success border-success' : '' %>
                    <%= game.status === 'completed' ? 'bg-primary border-primary' : '' %>
                    <%= game.status === 'waiting' ? 'bg-warning text-dark border-warning' : '' %>
                    <%= game.status === 'disputed' ? 'bg-danger border-danger' : '' %>
                    <%= !game.status || !['active', 'completed', 'waiting', 'disputed'].includes(game.status) ? 'bg-secondary border-secondary' : '' %>"
                    style="backdrop-filter: blur(10px); --bs-bg-opacity: .8;">
                    <i class="fas fa-circle fa-xs me-2"></i>
                    <%= game.status ? game.status.toUpperCase() : 'UNKNOWN' %>
                </span>
            </div>
        </div>

        <!-- Game Info Card -->
        <div class="glass-card mb-5 p-4" data-aos="fade-up">
            <div class="row g-4 justify-content-center text-center">
                <div class="col-md-4">
                    <div class="p-3">
                        <span class="text-white-50 d-block mb-2 text-uppercase small" style="letter-spacing: 0.05em;">Bet Amount</span>
                        <span class="text-white fw-bold fs-2">₹<%= game.betAmount ? game.betAmount.toLocaleString() : '0' %></span>
                    </div>
                </div>
                <div class="col-md-4 border-start border-end" style="border-color: rgba(255,255,255,0.1) !important;">
                    <div class="p-3">
                        <span class="text-white-50 d-block mb-2 text-uppercase small" style="letter-spacing: 0.05em;">Total Pot</span>
                        <span class="text-warning fw-bold fs-2">₹<%= game.betAmount ? (game.betAmount * 2).toLocaleString() : '0' %></span>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="p-3">
                        <span class="text-white-50 d-block mb-2 text-uppercase small" style="letter-spacing: 0.05em;">Game Created</span>
                        <span class="text-white fw-medium fs-5">
                            <% if (game.createdAt) { %>
                                <%= new Date(game.createdAt).toLocaleDateString('en-IN', { day: 'numeric', month: 'short', year: 'numeric', hour: '2-digit', minute: '2-digit' }) %>
                            <% } else { %>
                                N/A
                            <% } %>
                        </span>
                    </div>
                </div>
            </div>
        </div>

        <!-- Players Section -->
        <div class="row justify-content-center mb-5 align-items-center" data-aos="fade-up" data-aos-delay="100">
            <div class="col-12 mb-4">
                <h3 class="text-white fw-bold border-bottom pb-3" style="border-color: rgba(255,255,255,0.1) !important;">
                    <i class="fas fa-users text-primary me-2"></i> Players
                </h3>
            </div>
            
            <div class="col-md-5">
                <!-- Player 1 -->
                <% if (game.player1) { %>
                    <% 
                        var player1Id = game.player1._id ? game.player1._id.toString() : null; 
                        var currentUserId = user && user._id ? user._id.toString() : null; 
                        var isCurrentUser = player1Id && currentUserId && player1Id === currentUserId; 
                    %>
                    <div class="glass-card p-4 text-center h-100 <%= isCurrentUser ? 'border-primary border border-opacity-50' : '' %> position-relative">
                        <% if (game.winner && game.winner._id && game.player1._id && game.winner._id.toString() === game.player1._id.toString()) { %>
                            <div class="position-absolute top-0 start-50 translate-middle">
                                <span class="bg-warning text-dark rounded-circle d-flex align-items-center justify-content-center shadow-lg" style="width: 40px; height: 40px; border: 3px solid #1a1a2e;"><i class="fas fa-crown"></i></span>
                            </div>
                        <% } %>
                        
                        <div class="rounded-circle bg-primary bg-gradient mx-auto d-flex align-items-center justify-content-center text-white fw-bold shadow-lg mb-3 mt-2" style="width: 80px; height: 80px; font-size: 2rem; border: 4px solid rgba(255,255,255,0.1);">
                            <%= game.player1.username ? game.player1.username.charAt(0).toUpperCase() : 'P1' %>
                        </div>
                        
                        <h4 class="text-white fw-bold mb-1">
                            <%= game.player1.username || 'Player 1' %>
                            <% if (isCurrentUser) { %>
                                <span class="badge bg-primary bg-opacity-25 text-primary border border-primary fw-normal ms-1 fs-6 align-middle">(You)</span>
                            <% } %>
                        </h4>
                        
                        <div class="d-flex justify-content-center gap-3 mt-3 text-white-50 small">
                            <span><i class="fas fa-trophy text-warning me-1"></i> <%= game.player1.totalWins || 0 %> wins</span>
                            <span><i class="fas fa-gamepad text-info me-1"></i> <%= game.player1.totalGames || 0 %> games</span>
                        </div>
                        
                        <div class="mt-4 pt-3 border-top" style="border-color: rgba(255,255,255,0.1) !important;">
                            <span class="text-success small fw-medium"><i class="fas fa-circle fa-xs me-1"></i> Active</span>
                        </div>
                    </div>
                <% } else { %>
                    <div class="glass-card p-4 text-center h-100 opacity-75">
                        <div class="rounded-circle bg-dark mx-auto d-flex align-items-center justify-content-center text-white-50 fw-bold border mb-3 mt-2" style="width: 80px; height: 80px; font-size: 2rem; border-color: rgba(255,255,255,0.1) !important; border-style: dashed !important;">?</div>
                        <h4 class="text-white-50 fw-bold mb-2">Player 1</h4>
                        <div class="mt-4 pt-3 border-top" style="border-color: rgba(255,255,255,0.1) !important;">
                            <span class="text-warning small"><i class="fas fa-clock me-1"></i> Waiting</span>
                        </div>
                    </div>
                <% } %>
            </div>
            
            <div class="col-md-2 text-center my-4 my-md-0">
                <div class="rounded-circle bg-dark bg-opacity-50 mx-auto d-flex align-items-center justify-content-center text-primary fw-bold shadow-lg border" style="width: 60px; height: 60px; font-size: 1.5rem; border-color: rgba(255,255,255,0.1) !important;">VS</div>
            </div>
            
            <div class="col-md-5">
                <!-- Player 2 -->
                <% if (game.player2) { %>
                    <% 
                        var player2Id = game.player2._id ? game.player2._id.toString() : null; 
                        var currentUserId2 = user && user._id ? user._id.toString() : null; 
                        var isCurrentUser2 = player2Id && currentUserId2 && player2Id === currentUserId2; 
                    %>
                    <div class="glass-card p-4 text-center h-100 <%= isCurrentUser2 ? 'border-primary border border-opacity-50' : '' %> position-relative">
                        <% if (game.winner && game.winner._id && game.player2._id && game.winner._id.toString() === game.player2._id.toString()) { %>
                            <div class="position-absolute top-0 start-50 translate-middle">
                                <span class="bg-warning text-dark rounded-circle d-flex align-items-center justify-content-center shadow-lg" style="width: 40px; height: 40px; border: 3px solid #1a1a2e;"><i class="fas fa-crown"></i></span>
                            </div>
                        <% } %>
                        
                        <div class="rounded-circle bg-danger bg-gradient mx-auto d-flex align-items-center justify-content-center text-white fw-bold shadow-lg mb-3 mt-2" style="width: 80px; height: 80px; font-size: 2rem; border: 4px solid rgba(255,255,255,0.1);">
                            <%= game.player2.username ? game.player2.username.charAt(0).toUpperCase() : 'P2' %>
                        </div>
                        
                        <h4 class="text-white fw-bold mb-1">
                            <%= game.player2.username || 'Player 2' %>
                            <% if (isCurrentUser2) { %>
                                <span class="badge bg-primary bg-opacity-25 text-primary border border-primary fw-normal ms-1 fs-6 align-middle">(You)</span>
                            <% } %>
                        </h4>
                        
                        <div class="d-flex justify-content-center gap-3 mt-3 text-white-50 small">
                            <span><i class="fas fa-trophy text-warning me-1"></i> <%= game.player2.totalWins || 0 %> wins</span>
                            <span><i class="fas fa-gamepad text-info me-1"></i> <%= game.player2.totalGames || 0 %> games</span>
                        </div>
                        
                        <div class="mt-4 pt-3 border-top" style="border-color: rgba(255,255,255,0.1) !important;">
                            <span class="text-success small fw-medium"><i class="fas fa-circle fa-xs me-1"></i> Active</span>
                        </div>
                    </div>
                <% } else { %>
                    <div class="glass-card p-4 text-center h-100 border border-dashed bg-black bg-opacity-25" style="border-color: rgba(255,255,255,0.1) !important;">
                        <div class="rounded-circle bg-dark mx-auto d-flex align-items-center justify-content-center text-white-50 fw-bold border mb-3 mt-2" style="width: 80px; height: 80px; font-size: 2rem; border-color: rgba(255,255,255,0.1) !important;"><i class="fas fa-clock"></i></div>
                        <h4 class="text-white mb-2">Waiting for Player</h4>
                        <p class="text-white-50 small mb-4">Share room ID to invite</p>
                        
                        <div class="bg-dark bg-opacity-50 rounded p-2 d-flex align-items-center justify-content-between mx-auto" style="max-width: 200px;">
                            <span class="font-monospace text-primary fw-bold px-2"><%= game.roomId %></span>
                            <button class="btn btn-sm btn-outline-light border-0" onclick="copyRoomId()"><i class="fas fa-copy"></i></button>
                        </div>
                    </div>
                <% } %>
            </div>
        </div>

        <!-- Game Result Section (if completed) -->
        <% if (game.status === 'completed' && game.winner) { %>
            <div class="glass-card mb-5 border-success border border-opacity-25 overflow-hidden" data-aos="zoom-in">
                <div class="bg-success bg-opacity-25 p-3 border-bottom border-success border-opacity-25 d-flex align-items-center">
                    <i class="fas fa-trophy text-warning fs-4 me-3"></i>
                    <h5 class="text-white mb-0 fw-bold">Game Result</h5>
                </div>
                <div class="p-4 p-md-5 text-center" style="background: linear-gradient(to bottom, rgba(28, 200, 138, 0.1), transparent);">
                    <p class="text-success text-uppercase fw-bold mb-2" style="letter-spacing: 0.05em;">Winner</p>
                    <h1 class="display-3 fw-bold text-white mb-3 text-gradient"><%= game.winner.username || 'Player' %></h1>
                    <div class="d-inline-block bg-dark bg-opacity-50 rounded-pill px-4 py-2 border mx-auto mb-4" style="border-color: rgba(255,255,255,0.1) !important;">
                        <span class="text-white-50 me-2">Prize:</span>
                        <span class="text-warning fs-4 fw-bold">₹<%= game.betAmount ? (game.betAmount * 2).toLocaleString() : '0' %></span>
                    </div>

                    <% if (game.screenshot) { %>
                        <div class="mt-4 pt-4 border-top" style="border-color: rgba(255,255,255,0.1) !important;">
                            <h5 class="text-white mb-3">Winning Evidence</h5>
                            <button class="btn btn-outline-light rounded-pill px-4" onclick="viewScreenshot()">
                                <i class="fas fa-image me-2"></i> View Screenshot
                            </button>
                        </div>
                    <% } %>
                </div>
            </div>
        <% } %>

        <!-- Game Actions -->
        <h3 class="text-white fw-bold mb-4 border-bottom pb-3" style="border-color: rgba(255,255,255,0.1) !important;" data-aos="fade-up">
            <i class="fas fa-bolt text-warning me-2"></i> Actions & Info
        </h3>
        <style>
            .hover-lift { transition: transform 0.2s ease, box-shadow 0.2s ease; }
            .hover-lift:hover { transform: translateY(-5px); box-shadow: 0 10px 25px rgba(0,0,0,0.2) !important; }
        </style>
        <div class="row g-4 mb-5" data-aos="fade-up" data-aos-delay="100">
            <!-- Room ID Card -->
            <div class="col-md-4">
                <div class="glass-card p-4 text-center h-100 hover-lift">
                    <div class="rounded bg-primary bg-gradient text-white d-inline-flex align-items-center justify-content-center p-3 mb-3" style="width: 60px; height: 60px; font-size: 1.5rem;">
                        <i class="fas fa-door-open"></i>
                    </div>
                    <h5 class="text-white mb-2">Room ID</h5>
                    <p class="font-monospace text-gradient fs-4 fw-bold mb-3"><%= game.roomId %></p>
                    <button class="btn btn-outline-light btn-sm rounded-pill w-100" onclick="copyRoomId()">
                        <i class="fas fa-copy me-1"></i> Copy Room ID
                    </button>
                </div>
            </div>

            <!-- Ludo King App Card -->
            <div class="col-md-4">
                <div class="glass-card p-4 text-center h-100 hover-lift">
                    <div class="rounded bg-success bg-gradient text-white d-inline-flex align-items-center justify-content-center p-3 mb-3" style="width: 60px; height: 60px; font-size: 1.5rem;">
                        <i class="fas fa-mobile-alt"></i>
                    </div>
                    <h5 class="text-white mb-2">Open Ludo King</h5>
                    <p class="text-white-50 small mb-3">Enter the room ID in Ludo King app to play</p>
                    <button class="btn btn-success btn-sm rounded-pill w-100" onclick="openLudoKing()">
                        <i class="fas fa-external-link-alt me-1"></i> Open App
                    </button>
                </div>
            </div>

            <!-- Game Status Action Card -->
            <div class="col-md-4">
                <div class="glass-card p-4 text-center h-100 hover-lift">
                    <div class="rounded bg-warning bg-gradient text-dark d-inline-flex align-items-center justify-content-center p-3 mb-3" style="width: 60px; height: 60px; font-size: 1.5rem;">
                        <i class="fas fa-info-circle"></i>
                    </div>
                    <h5 class="text-white mb-2">Status</h5>
                    <p class="text-uppercase fw-bold text-gradient mb-3"><%= game.status || 'unknown' %></p>
                    
                    <% if (game.status === 'waiting') { %>
                        <button class="btn btn-primary btn-sm rounded-pill w-100" onclick="copyRoomId()">
                            <i class="fas fa-share-alt me-1"></i> Share Room ID
                        </button>
                    <% } else if (game.status === 'active') { %>
                        <a href="/games/<%= game._id %>/play" class="btn btn-primary btn-sm rounded-pill w-100">
                            <i class="fas fa-play me-1"></i> Continue Game
                        </a>
                    <% } else if (game.status === 'completed') { %>
                        <p class="text-white-50 small mb-0">
                            Completed <%= game.completedAt ? new Date(game.completedAt).toLocaleDateString() : 'recently' %>
                        </p>
                    <% } else if (game.status === 'disputed') { %>
                        <a href="/support" class="btn btn-danger btn-sm rounded-pill w-100">
                            <i class="fas fa-headset me-1"></i> Contact Support
                        </a>
                    <% } %>
                </div>
            </div>
        </div>

        <!-- Share Section (if waiting) -->
        <% if (game.status === 'waiting') { %>
            <div class="glass-card mb-5 p-4 text-center" data-aos="fade-up">
                <h3 class="text-white fw-bold mb-3"><i class="fas fa-share-alt text-primary me-2"></i> Share Game</h3>
                <p class="text-white-50 mb-4">Share this room ID with a friend to play together:</p>

                <div class="d-flex flex-wrap justify-content-center gap-3">
                    <button class="btn btn-outline-light rounded-pill px-4" style="border-color: #25D366; color: #25D366;" onclick="shareWhatsApp()">
                        <i class="fab fa-whatsapp me-2"></i> WhatsApp
                    </button>
                    <button class="btn btn-outline-light rounded-pill px-4" style="border-color: #0088cc; color: #0088cc;" onclick="shareTelegram()">
                        <i class="fab fa-telegram me-2"></i> Telegram
                    </button>
                    <button class="btn btn-outline-light rounded-pill px-4" onclick="shareSMS()">
                        <i class="fas fa-sms me-2"></i> SMS
                    </button>
                </div>
            </div>
        <% } %>
    </div>
</div>

<!-- Screenshot Modal -->
<div class="modal fade" id="screenshotModal" tabindex="-1">
    <div class="modal-dialog modal-lg modal-dialog-centered">
        <div class="modal-content glass-card border-0 shadow-lg">
            <div class="modal-header border-bottom" style="border-color: rgba(255,255,255,0.1) !important;">
                <h5 class="modal-title text-white fw-bold"><i class="fas fa-image text-primary me-2"></i> Game Evidence</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body text-center p-4 bg-dark">
                <img src="<%= game.screenshot %>" class="img-fluid rounded shadow" alt="Game Screenshot" style="max-height: 70vh; object-fit: contain;">
            </div>
        </div>
    </div>
</div>

<script>
    function copyRoomId() {
        var roomId = '<%= game.roomId %>';
        navigator.clipboard.writeText(roomId).then(function () {
            alert('Room ID copied to clipboard!');
        }).catch(function (err) {
            alert('Failed to copy. Please manually copy: ' + roomId);
        });
    }

    function viewScreenshot() {
        var modal = new bootstrap.Modal(document.getElementById('screenshotModal'));
        modal.show();
    }

    function openLudoKing() {
        alert('This would open the Ludo King app directly. For now, please open the app manually and enter room ID: ' + '<%= game.roomId %>');
    }

    function shareWhatsApp() {
        var text = encodeURIComponent('Join me on Ludo! My Room ID is *<%= game.roomId %>*. Install Ludo King to play.');
        window.open('https://api.whatsapp.com/send?text=' + text);
    }

    function shareTelegram() {
        var text = encodeURIComponent('Join me on Ludo! My Room ID is ' + '<%= game.roomId %>' + '.');
        window.open('https://t.me/share/url?url=' + encodeURIComponent(window.location.origin) + '&text=' + text);
    }

    function shareSMS() {
        var text = encodeURIComponent('Join me on Ludo! My Room ID is ' + '<%= game.roomId %>' + '.');
        window.open('sms:?&body=' + text);
    }
</script>

<%- include('../partials/footer') %>