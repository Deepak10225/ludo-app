<%- include('../partials/header') %>

    <div class="container">
        <div class="row justify-content-center">
            <div class="col-md-8">
                <div class="card">
                    <div class="card-header bg-success text-white">
                        <h4 class="mb-0">
                            <i class="fas fa-play-circle"></i> Game Active
                        </h4>
                    </div>

                    <div class="card-body text-center">
                        <!-- Room ID Display -->
                        <div class="alert alert-info">
                            <h5>Room ID:</h5>
                            <h2 class="display-4" id="roomId">
                                <%= game.roomId %>
                            </h2>
                            <button class="btn btn-primary mt-2" onclick="copyRoomId()">
                                <i class="fas fa-copy"></i> Copy Room ID
                            </button>
                        </div>

                        <p class="text-muted">
                            Open Ludo King app and enter this room ID to play
                        </p>

                        <!-- Game Details -->
                        <div class="row mt-4">
                            <div class="col-md-6">
                                <div class="card">
                                    <div class="card-body">
                                        <h6>Player 1</h6>
                                        <h5>
                                            <%= game.player1.username %>
                                        </h5>
                                    </div>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="card">
                                    <div class="card-body">
                                        <h6>Player 2</h6>
                                        <h5>
                                            <%= game.player2.username %>
                                        </h5>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="row mt-3">
                            <div class="col">
                                <h6>Bet Amount:</h6>
                                <h3 class="text-success">₹<%= game.betAmount.toLocaleString() %>
                                </h3>
                            </div>
                            <div class="col">
                                <h6>Total Prize:</h6>
                                <h3 class="text-primary">₹<%= (game.betAmount * 2).toLocaleString() %>
                                </h3>
                            </div>
                        </div>

                        <!-- Result Submission -->
                        <div class="card mt-4">
                            <div class="card-header">
                                <h5 class="mb-0">Submit Game Result</h5>
                            </div>
                            <div class="card-body">
                                <p>After completing the game, upload a screenshot showing the winner:</p>

                                <form action="/games/<%= game._id %>/result" method="POST"
                                    enctype="multipart/form-data">
                                    <div class="mb-3">
                                        <input type="file" name="screenshot" class="form-control" accept="image/*"
                                            required>
                                    </div>
                                    <button type="submit" class="btn btn-success">
                                        <i class="fas fa-upload"></i> I Won - Submit Screenshot
                                    </button>
                                </form>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <script>
        function copyRoomId() {
            const roomId = document.getElementById('roomId').innerText;
            navigator.clipboard.writeText(roomId).then(() => {
                alert('Room ID copied to clipboard!');
            });
        }

        // Auto-refresh to check game status every 30 seconds
        setTimeout(() => {
            location.reload();
        }, 30000);
    </script>

    <%- include('../partials/footer') %>