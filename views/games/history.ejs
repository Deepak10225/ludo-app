<%- include('../partials/header') %>

<div class="history-container" style="min-height: 100vh; padding: 100px 0; position: relative;">
    <div class="hero-bg"></div>
    <div class="container">
        <!-- Header -->
        <div class="row align-items-center mb-5" data-aos="fade-down">
            <div class="col-md-8">
                <h1 class="fw-bold text-white mb-2">
                    <i class="fas fa-history text-gradient me-2"></i> Game History
                </h1>
                <p class="text-white-50 fs-5 mb-0">Track all your games and performance</p>
            </div>
            <div class="col-md-4 text-md-end mt-4 mt-md-0">
                <div class="d-flex justify-content-md-end gap-3">
                    <div class="glass-card py-2 px-4 rounded-pill d-inline-block border border-white-10">
                        <span class="text-white-50 me-2"><i class="fas fa-gamepad"></i> Total:</span>
                        <span class="text-white fw-bold fs-5"><%= pagination?.total || 0 %></span>
                    </div>
                    <div class="glass-card py-2 px-4 rounded-pill d-inline-block border border-warning border-opacity-50" style="background: rgba(246, 194, 62, 0.1);">
                        <span class="text-warning me-2"><i class="fas fa-trophy"></i> Wins:</span>
                        <span class="text-warning fw-bold fs-5"><%= user.totalWins || 0 %></span>
                    </div>
                </div>
            </div>
        </div>

        <!-- Filters -->
        <div class="glass-card p-4 mb-5 border-white-10 shadow" data-aos="fade-up">
            <div class="row g-3 align-items-center">
                <div class="col-md-3">
                    <select class="form-select bg-dark text-white border-white-20 py-2 custom-select" id="statusFilter">
                        <option value="all">All Status</option>
                        <option value="waiting">Waiting</option>
                        <option value="active">Active</option>
                        <option value="completed">Completed</option>
                        <option value="disputed">Disputed</option>
                    </select>
                </div>
                <div class="col-md-3">
                    <select class="form-select bg-dark text-white border-white-20 py-2 custom-select" id="resultFilter">
                        <option value="all">All Results</option>
                        <option value="won">Won</option>
                        <option value="lost">Lost</option>
                        <option value="pending">Pending</option>
                    </select>
                </div>
                <div class="col-md-3">
                    <select class="form-select bg-dark text-white border-white-20 py-2 custom-select" id="rangeFilter">
                        <option value="all">All Bet Ranges</option>
                        <option value="100-25000">₹100 - ₹25,000</option>
                        <option value="25000-100000">₹25,000 - ₹1,00,000</option>
                    </select>
                </div>
                <div class="col-md-3">
                    <div class="position-relative">
                        <i class="fas fa-search position-absolute text-white-50" style="left: 15px; top: 50%; transform: translateY(-50%);"></i>
                        <input type="text" class="form-control bg-dark text-white border-white-20 py-2 ps-5" id="searchInput" placeholder="Search Room ID...">
                    </div>
                </div>
            </div>
        </div>

        <!-- Games List -->
        <div class="glass-card p-4 p-md-5 border-white-10 shadow-lg" data-aos="fade-up" data-aos-delay="100">
            <% if (games && games.length > 0) { %>
                <div class="games-list d-flex flex-column gap-4">
                    <% games.forEach(game => {
                        const isPlayer1 = game.player1 && game.player1._id.toString() === user._id.toString();
                        const isPlayer2 = game.player2 && game.player2._id.toString() === user._id.toString();
                        const opponent = isPlayer1 ? game.player2 : game.player1;
                        const userWon = game.winner && game.winner._id.toString() === user._id.toString();
                        const gameStatus = game.status;
                        const betAmount = game.betAmount || 0;
                        const winnings = game.winnings || betAmount * 2;
                        
                        let borderClass = 'border-white-10 border-start-4';
                        if (game.status === 'completed') borderClass = 'border-success border border-opacity-50 border-start-4';
                        if (game.status === 'active') borderClass = 'border-primary border border-opacity-50 border-start-4';
                        if (game.status === 'waiting') borderClass = 'border-warning border border-opacity-50 border-start-4';
                        if (game.status === 'disputed') borderClass = 'border-danger border border-opacity-50 border-start-4';
                    %>
                        <div class="game-item rounded-4 p-4 bg-dark bg-opacity-50 <%= borderClass %> position-relative overflow-hidden hover-lift" 
                            data-status="<%= game.status %>"
                            data-result="<%= game.winner ? (userWon ? 'won' : 'lost') : 'pending' %>"
                            data-range="<%= game.betRange %>" 
                            data-room="<%= game.roomId %>"
                            style="border-left-width: 4px !important;">
                            
                            <!-- Status Background Glow -->
                            <div class="position-absolute top-0 start-0 w-100 h-100 opacity-10 pointer-events-none status-glow-<%= game.status %>"></div>

                            <!-- Game Header -->
                            <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center mb-4 pb-3 border-bottom border-white-10 position-relative z-1">
                                <div class="d-flex align-items-center gap-3 mb-2 mb-md-0">
                                    <span class="text-white-50">Room ID:</span>
                                    <span class="font-monospace text-primary fw-bold fs-5 tracking-wide"><%= game.roomId %></span>
                                    <button class="btn btn-sm btn-outline-light border-0 rounded-pill p-1 px-2" onclick="copyRoomId('<%= game.roomId %>')" title="Copy Room ID">
                                        <i class="fas fa-copy"></i>
                                    </button>
                                </div>
                                <div class="text-white-50 small d-flex align-items-center">
                                    <i class="far fa-calendar-alt me-2 text-primary"></i>
                                    <%= new Date(game.createdAt).toLocaleDateString('en-IN', { day: 'numeric', month: 'short', year: 'numeric', hour: '2-digit', minute: '2-digit' }) %>
                                </div>
                            </div>

                            <!-- Game Content -->
                            <div class="row g-4 align-items-center position-relative z-1">
                                <!-- Players column -->
                                <div class="col-lg-5">
                                    <div class="d-flex align-items-center justify-content-between bg-black bg-opacity-25 rounded-pill p-2 border border-white-10">
                                        <!-- Player 1 / You -->
                                        <div class="d-flex align-items-center gap-2 <%= isPlayer1 ? 'opacity-100' : 'opacity-75' %>" style="width: 40%;">
                                            <div class="rounded-circle bg-primary bg-gradient d-flex align-items-center justify-content-center text-white fw-bold flex-shrink-0 border border-white-20 position-relative" style="width: 40px; height: 40px; font-size: 1.2rem;">
                                                <%= game.player1 ? game.player1.username.charAt(0).toUpperCase() : '?' %>
                                                <% if (game.winner && game.winner._id.toString() === (game.player1 ? game.player1._id.toString() : '')) { %>
                                                    <span class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-warning text-dark p-1 border border-dark"><i class="fas fa-crown fa-xs"></i></span>
                                                <% } %>
                                            </div>
                                            <div class="text-truncate">
                                                <div class="text-white fw-bold small text-truncate"><%= game.player1 ? game.player1.username : 'P1' %></div>
                                                <% if (isPlayer1) { %><div class="text-primary" style="font-size: 0.7rem;">(You)</div><% } %>
                                            </div>
                                        </div>

                                        <div class="text-white-50 fw-bold small">VS</div>

                                        <!-- Player 2 / Opponent -->
                                        <div class="d-flex align-items-center justify-content-end gap-2 text-end <%= isPlayer2 ? 'opacity-100' : 'opacity-75' %>" style="width: 40%;">
                                            <div class="text-truncate">
                                                <div class="text-white fw-bold small text-truncate"><%= game.player2 ? game.player2.username : 'Waiting...' %></div>
                                                <% if (isPlayer2) { %><div class="text-primary" style="font-size: 0.7rem;">(You)</div><% } %>
                                            </div>
                                            <div class="rounded-circle bg-danger bg-gradient d-flex align-items-center justify-content-center text-white fw-bold flex-shrink-0 border border-white-20 position-relative" style="width: 40px; height: 40px; font-size: 1.2rem;">
                                                <%= game.player2 ? game.player2.username.charAt(0).toUpperCase() : '?' %>
                                                <% if (game.winner && game.player2 && game.winner._id.toString() === game.player2._id.toString()) { %>
                                                    <span class="position-absolute top-0 start-0 translate-middle badge rounded-pill bg-warning text-dark p-1 border border-dark"><i class="fas fa-crown fa-xs"></i></span>
                                                <% } %>
                                            </div>
                                        </div>
                                    </div>
                                </div>

                                <!-- Financials column -->
                                <div class="col-lg-4 text-center border-start border-end border-white-10 py-2">
                                    <div class="d-flex justify-content-center gap-4">
                                        <div>
                                            <div class="text-white-50 small mb-1">Bet Amount</div>
                                            <div class="text-white fw-bold">₹<%= betAmount.toLocaleString() %></div>
                                        </div>
                                        <div class="border-start border-white-20"></div>
                                        <div>
                                            <div class="text-white-50 small mb-1">Total Pot</div>
                                            <div class="text-warning fw-bold">₹<%= (betAmount * 2).toLocaleString() %></div>
                                        </div>
                                    </div>
                                </div>

                                <!-- Status / Action column -->
                                <div class="col-lg-3 d-flex flex-column align-items-center align-items-lg-end gap-2">
                                    <% if (game.status === 'completed' && game.winner) { %>
                                        <% if (userWon) { %>
                                            <span class="badge bg-success bg-opacity-25 text-success border border-success px-3 py-2 rounded-pill fs-6 w-100 text-center"><i class="fas fa-trophy me-2"></i> Won ₹<%= winnings.toLocaleString() %></span>
                                        <% } else { %>
                                            <span class="badge bg-danger bg-opacity-25 text-danger border border-danger px-3 py-2 rounded-pill fs-6 w-100 text-center"><i class="fas fa-times-circle me-2"></i> Lost</span>
                                        <% } %>
                                    <% } else if (game.status === 'waiting') { %>
                                        <span class="badge bg-warning bg-opacity-25 text-warning border border-warning px-3 py-2 rounded-pill fs-6 w-100 text-center"><i class="fas fa-clock me-2"></i> Waiting</span>
                                    <% } else if (game.status === 'active') { %>
                                        <span class="badge bg-primary bg-opacity-25 text-primary border border-primary px-3 py-2 rounded-pill fs-6 w-100 text-center"><i class="fas fa-play me-2"></i> In Progress</span>
                                    <% } else if (game.status === 'disputed') { %>
                                        <span class="badge bg-danger bg-opacity-25 text-danger border border-danger px-3 py-2 rounded-pill fs-6 w-100 text-center"><i class="fas fa-exclamation-triangle me-2"></i> Disputed</span>
                                    <% } %>

                                    <!-- Action Buttons -->
                                    <div class="d-flex gap-2 w-100 mt-1">
                                        <% if (game.status === 'active') { %>
                                            <a href="/games/<%= game._id %>/play" class="btn btn-primary btn-sm flex-fill rounded-pill"><i class="fas fa-play me-1"></i> Play</a>
                                        <% } else { %>
                                            <a href="/games/<%= game._id %>" class="btn btn-outline-light btn-sm flex-fill rounded-pill"><i class="fas fa-eye me-1"></i> Details</a>
                                        <% } %>
                                        
                                        <% if (game.screenshot) { %>
                                            <button class="btn btn-outline-info btn-sm rounded-pill px-2" onclick="viewScreenshot('<%= game.screenshot %>')" title="View Screenshot">
                                                <i class="fas fa-image"></i>
                                            </button>
                                        <% } %>
                                    </div>
                                </div>
                            </div>
                        </div>
                    <% }) %>
                </div>

                <!-- Pagination -->
                <% if (pagination && pagination.pages > 1) { %>
                    <nav class="mt-5" aria-label="Game history pagination">
                        <ul class="pagination justify-content-center">
                            <li class="page-item <%= pagination.page === 1 ? 'disabled' : '' %>">
                                <a class="page-link bg-dark text-white border-white-20 hover-bg-primary" href="?page=<%= pagination.page - 1 %>">
                                    <i class="fas fa-chevron-left"></i>
                                </a>
                            </li>

                            <% for(let i = 1; i <= pagination.pages; i++) { %>
                                <li class="page-item <%= pagination.page === i ? 'active' : '' %>">
                                    <a class="page-link <%= pagination.page === i ? 'bg-primary border-primary text-white' : 'bg-dark text-white border-white-20 hover-bg-primary' %>" href="?page=<%= i %>">
                                        <%= i %>
                                    </a>
                                </li>
                            <% } %>

                            <li class="page-item <%= pagination.page === pagination.pages ? 'disabled' : '' %>">
                                <a class="page-link bg-dark text-white border-white-20 hover-bg-primary" href="?page=<%= pagination.page + 1 %>">
                                    <i class="fas fa-chevron-right"></i>
                                </a>
                            </li>
                        </ul>
                    </nav>
                <% } %>
            <% } else { %>
                <div class="text-center py-5">
                    <div class="bg-dark bg-opacity-50 rounded-circle d-inline-flex align-items-center justify-content-center mb-4 border border-white-10" style="width: 120px; height: 120px;">
                        <i class="fas fa-dice fa-4x text-white-50 opacity-50"></i>
                    </div>
                    <h3 class="text-white fw-bold mb-3">No Games Yet</h3>
                    <p class="text-white-50 mb-4 max-w-md mx-auto">You haven't played any games yet. Start playing now to build your history and claim your place on the leaderboard!</p>
                    <a href="/games" class="btn btn-primary btn-lg rounded-pill px-5 hover-lift">
                        <i class="fas fa-gamepad me-2"></i>Play Now
                    </a>
                </div>
            <% } %>
        </div>
    </div>
</div>

<!-- Screenshot Modal -->
<div class="modal fade" id="screenshotModal" tabindex="-1">
    <div class="modal-dialog modal-lg modal-dialog-centered">
        <div class="modal-content glass-card border-0 shadow-lg">
            <div class="modal-header border-bottom border-white-10">
                <h5 class="modal-title text-white fw-bold"><i class="fas fa-image text-primary me-2"></i> Game Screenshot</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body text-center p-4 bg-dark">
                <img src="" id="screenshotImage" class="img-fluid rounded shadow" alt="Game Screenshot" style="max-height: 70vh; object-fit: contain;">
            </div>
            <div class="modal-footer border-top border-white-10">
                <button type="button" class="btn btn-outline-light rounded-pill px-4" data-bs-dismiss="modal">Close</button>
            </div>
        </div>
    </div>
</div>

<style>
    .tracking-wide { letter-spacing: 0.1em; }
    .border-white-10 { border-color: rgba(255, 255, 255, 0.1) !important; }
    .border-white-20 { border-color: rgba(255, 255, 255, 0.2) !important; }
    
    .custom-select {
        background-image: url("data:image/svg+xml,%3csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 16 16'%3e%3cpath fill='none' stroke='%23ffffff' stroke-linecap='round' stroke-linejoin='round' stroke-width='2' d='m2 5 6 6 6-6'/%3e%3c/svg%3e");
        background-repeat: no-repeat;
        background-position: right 0.75rem center;
        background-size: 16px 12px;
    }
    
    .hover-lift { transition: transform 0.2s ease, box-shadow 0.2s ease; }
    .hover-lift:hover { transform: translateY(-3px); box-shadow: 0 10px 25px rgba(0,0,0,0.3) !important; z-index: 10; }
    
    .status-glow-completed { background: radial-gradient(circle at 100% 50%, rgba(28, 200, 138, 0.2) 0%, transparent 50%); }
    .status-glow-active { background: radial-gradient(circle at 100% 50%, rgba(102, 126, 234, 0.2) 0%, transparent 50%); }
    .status-glow-waiting { background: radial-gradient(circle at 100% 50%, rgba(246, 194, 62, 0.2) 0%, transparent 50%); }
    .status-glow-disputed { background: radial-gradient(circle at 100% 50%, rgba(231, 74, 59, 0.2) 0%, transparent 50%); }

    .page-link { transition: all 0.2s ease; border-radius: 8px !important; margin: 0 3px; }
    .hover-bg-primary:hover { background-color: var(--primary-color) !important; border-color: var(--primary-color) !important; color: white !important; }
    .page-item.disabled .page-link { background-color: rgba(0,0,0,0.2) !important; border-color: rgba(255,255,255,0.05) !important; color: rgba(255,255,255,0.3) !important; }
</style>

<script>
    // Copy room ID
    function copyRoomId(roomId) {
        navigator.clipboard.writeText(roomId).then(function () {
            alert('Room ID copied: ' + roomId);
        }).catch(function (err) {
            console.error('Failed to copy', err);
        });
    }

    // View screenshot
    function viewScreenshot(url) {
        document.getElementById('screenshotImage').src = url;
        var modal = new bootstrap.Modal(document.getElementById('screenshotModal'));
        modal.show();
    }

    // Filtering logic
    document.addEventListener('DOMContentLoaded', function() {
        const statusFilter = document.getElementById('statusFilter');
        const resultFilter = document.getElementById('resultFilter');
        const rangeFilter = document.getElementById('rangeFilter');
        const searchInput = document.getElementById('searchInput');
        const gamesList = document.querySelectorAll('.game-item');

        function filterGames() {
            const status = statusFilter.value;
            const result = resultFilter.value;
            const range = rangeFilter.value;
            const search = searchInput.value.toLowerCase().trim();

            gamesList.forEach(game => {
                const gameStatus = game.getAttribute('data-status');
                const gameResult = game.getAttribute('data-result');
                const gameRange = game.getAttribute('data-range');
                const gameRoom = game.getAttribute('data-room').toLowerCase();

                let showStatus = status === 'all' || gameStatus === status;
                let showResult = result === 'all' || gameResult === result;
                let showRange = range === 'all' || gameRange === range;
                let showSearch = search === '' || gameRoom.includes(search);

                if (showStatus && showResult && showRange && showSearch) {
                    game.style.display = 'block';
                } else {
                    game.style.display = 'none';
                }
            });
        }

        statusFilter.addEventListener('change', filterGames);
        resultFilter.addEventListener('change', filterGames);
        rangeFilter.addEventListener('change', filterGames);
        searchInput.addEventListener('input', filterGames);
    });
</script>

<%- include('../partials/footer') %>