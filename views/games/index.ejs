<%- include('../partials/header') %>

    <div class="games-container">
        <div class="container">
            <!-- Header -->
            <div class="games-header">
                <div class="row align-items-center">
                    <div class="col-md-8">
                        <h1 class="games-title">
                            <i class="fas fa-dice"></i> Play Ludo
                        </h1>
                        <p class="games-subtitle">Choose your bet amount and start playing</p>
                    </div>
                    <div class="col-md-4 text-md-end">
                        <div class="wallet-quick-info">
                            <span class="wallet-label">Your Balance:</span>
                            <span class="wallet-amount">₹<%= user.walletBalance ? user.walletBalance.toFixed(2) : '0.00'
                                    %></span>
                            <a href="/wallet" class="btn btn-sm btn-outline-primary ms-2">
                                <i class="fas fa-plus-circle"></i> Add
                            </a>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Bet Range Selection -->
            <div class="range-selector">
                <div class="btn-group w-100" role="group">
                    <a href="/games?range=100-25000" class="range-btn <%= range === '100-25000' ? 'active' : '' %>">
                        <span class="range-icon">🎲</span>
                        <span class="range-text">Beginner</span>
                        <span class="range-value">₹100 - ₹25,000</span>
                    </a>
                    <a href="/games?range=25000-100000"
                        class="range-btn <%= range === '25000-100000' ? 'active' : '' %>">
                        <span class="range-icon">👑</span>
                        <span class="range-text">Pro</span>
                        <span class="range-value">₹25,000 - ₹1,00,000</span>
                    </a>
                </div>
            </div>

            <div class="row">
                <!-- Left Column - Game Options -->
                <div class="col-lg-8">
                    <!-- Quick Bet Cards -->
                    <!-- Quick Bet Cards -->
                    <div class="quick-bets-card glass-card mb-4">
                        <div class="card-header border-bottom border-secondary p-4">
                            <h4><i class="fas fa-bolt"></i> Quick Bet</h4>
                            <p>Select your bet amount</p>
                        </div>
                        <div class="card-body">
                            <div class="bet-options">
                                <% if (options && options.length> 0) {
                                    options.forEach(function(amount) {
                                    var totalPot = amount * 2;
                                    var winnerAmount = totalPot * 0.9;
                                    var platformFee = totalPot * 0.1;
                                    %>
                                    <button class="bet-option" onclick="showCreateModal(<%= amount %>)"
                                        data-amount="<%= amount %>" data-win="<%= winnerAmount %>"
                                        data-fee="<%= platformFee %>">
                                        <span class="bet-amount">₹<%= amount.toLocaleString() %></span>
                                        <span class="bet-win">
                                            <i class="fas fa-trophy me-1"></i> Win ₹<%= winnerAmount.toLocaleString() %>
                                        </span>
                                    </button>
                                    <% }); } %>
                            </div>
                        </div>
                    </div>

                    <!-- Join with Room ID -->
                    <div class="join-card glass-card mb-4">
                        <div class="card-header border-bottom border-secondary p-4">
                            <h4><i class="fas fa-sign-in-alt"></i> Join with Room ID</h4>
                            <p>Enter the 6-digit room code</p>
                        </div>
                        <div class="card-body">
                            <form action="/games/join" method="POST" class="join-form"
                                onsubmit="return validateRoomId()">
                                <div class="input-group">
                                    <span class="input-group-text">
                                        <i class="fas fa-hashtag"></i>
                                    </span>
                                    <input type="text" name="roomId" id="roomId" class="form-control room-input"
                                        placeholder="Enter 6-digit Room ID" pattern="[0-9]{6}" maxlength="6"
                                        autocomplete="off" required>
                                    <button type="submit" class="btn btn-primary">
                                        <i class="fas fa-sign-in-alt"></i> Join Game
                                    </button>
                                </div>
                                <div class="form-text">
                                    <i class="fas fa-info-circle"></i> Enter the 6-digit room code from Ludo King
                                </div>
                            </form>
                        </div>
                    </div>

                    <!-- Waiting Games -->
                    <% if (waitingGames && waitingGames.length> 0) { %>
                        <div class="waiting-games-card glass-card mb-4">
                            <div class="card-header border-bottom border-secondary p-4">
                                <h4><i class="fas fa-clock"></i> Games Waiting for Players</h4>
                                <p>
                                    <%= waitingGames.length %> game(s) available
                                </p>
                            </div>
                            <div class="card-body">
                                <div class="waiting-games-list">
                                    <% // ✅ FIX: Use regular function with proper checks
                                        waitingGames.forEach(function(game) { var showGame=game && !game.player2 &&
                                        game.status==='waiting' ; if (showGame) { %>
                                        <div class="waiting-game-item">
                                            <div class="game-info">
                                                <div class="player-info">
                                                    <div class="player-avatar">
                                                        <%= game.player1 && game.player1.username ?
                                                            game.player1.username.charAt(0).toUpperCase() : '?' %>
                                                    </div>
                                                    <div class="player-details">
                                                        <span class="player-name">
                                                            <%= game.player1 ? game.player1.username : 'Unknown' %>
                                                        </span>
                                                        <span class="game-time">
                                                            <i class="far fa-clock"></i>
                                                            <%= game.createdAt ? new
                                                                Date(game.createdAt).toLocaleTimeString() : 'N/A' %>
                                                        </span>
                                                    </div>
                                                </div>
                                                <div class="bet-info">
                                                    <span class="bet-label">Bet</span>
                                                    <span class="bet-amount">₹<%= game.betAmount ?
                                                            game.betAmount.toLocaleString() : '0' %></span>
                                                    <span class="win-amount">Win ₹<%= game.betAmount ? (game.betAmount *
                                                            2).toLocaleString() : '0' %></span>
                                                </div>
                                            </div>
                                            <div class="game-actions">
                                                <span class="room-code-badge">
                                                    <i class="fas fa-door-open"></i>
                                                    <%= game.roomId || 'N/A' %>
                                                </span>
                                                <form action="/games/join" method="POST" class="d-inline">
                                                    <input type="hidden" name="roomId" value="<%= game.roomId %>">
                                                    <button type="submit" class="btn btn-success btn-sm">
                                                        <i class="fas fa-play"></i> Join Now
                                                    </button>
                                                </form>
                                            </div>
                                        </div>
                                        <% } }); %>
                                </div>
                            </div>
                        </div>
                        <% } else { %>
                            <div class="no-games-card">
                                <div class="card-body text-center py-5">
                                    <i class="fas fa-dice fa-4x text-muted mb-3"></i>
                                    <h5>No games waiting</h5>
                                    <p class="text-muted">Be the first to create a game!</p>
                                </div>
                            </div>
                            <% } %>
                </div>

                <!-- Right Column - Info & Stats -->
                <div class="col-lg-4">
                    <!-- How to Play Card -->
                    <div class="info-card">
                        <div class="card-header">
                            <h4><i class="fas fa-info-circle"></i> How to Play</h4>
                        </div>
                        <div class="card-body">
                            <div class="step-list">
                                <div class="step-item">
                                    <div class="step-number">1</div>
                                    <div class="step-content">
                                        <h6>Create or Join</h6>
                                        <p>Create a game or enter room ID</p>
                                    </div>
                                </div>
                                <div class="step-item">
                                    <div class="step-number">2</div>
                                    <div class="step-content">
                                        <h6>Get Room ID</h6>
                                        <p>Share the 6-digit code with opponent</p>
                                    </div>
                                </div>
                                <div class="step-item">
                                    <div class="step-number">3</div>
                                    <div class="step-content">
                                        <h6>Play in Ludo King</h6>
                                        <p>Open app and enter room ID</p>
                                    </div>
                                </div>
                                <div class="step-item">
                                    <div class="step-number">4</div>
                                    <div class="step-content">
                                        <h6>Upload Screenshot</h6>
                                        <p>Winner uploads proof to get paid</p>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Stats Card -->
                    <div class="stats-card mt-4">
                        <div class="card-header">
                            <h4><i class="fas fa-chart-line"></i> Platform Stats</h4>
                        </div>
                        <div class="card-body">
                            <div class="stat-item">
                                <span class="stat-label">Active Players</span>
                                <span class="stat-value">1,234</span>
                            </div>
                            <div class="stat-item">
                                <span class="stat-label">Games Today</span>
                                <span class="stat-value">567</span>
                            </div>
                            <div class="stat-item">
                                <span class="stat-label">Total Winnings</span>
                                <span class="stat-value text-success">₹12,34,567</span>
                            </div>
                        </div>
                    </div>

                    <!-- Support Card -->
                    <div class="support-card mt-4">
                        <div class="card-body text-center">
                            <i class="fas fa-headset fa-3x text-primary mb-3"></i>
                            <h5>Need Help?</h5>
                            <p class="text-muted small">24/7 Customer Support</p>
                            <a href="#" class="btn btn-outline-primary btn-sm" onclick="showSupport()">
                                <i class="fas fa-comment"></i> Live Chat
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Create Game Modal -->
    <div class="modal fade" id="createGameModal" tabindex="-1">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">
                        <i class="fas fa-plus-circle text-primary"></i> Create New Game
                    </h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <form action="/games/create" method="POST">
                    <input type="hidden" name="betRange" value="<%= range %>">
                    <input type="hidden" name="betAmount" id="modalBetAmount">

                    <div class="modal-body">
                        <div class="text-center mb-4">
                            <div class="bet-preview">
                                <span class="preview-label">Bet Amount</span>
                                <span class="preview-amount" id="modalAmountDisplay">₹0</span>
                            </div>
                        </div>

                        <div class="game-preview-info">
                            <div class="preview-item">
                                <i class="fas fa-tag"></i>
                                <span>Range: <strong>
                                        <%= range %>
                                    </strong></span>
                            </div>
                            <div class="preview-item">
                                <i class="fas fa-trophy"></i>
                                <span>Win: <strong id="modalWinDisplay">₹0</strong></span>
                            </div>
                            <div class="preview-item">
                                <i class="fas fa-wallet"></i>
                                <span>Your Balance: <strong>₹<%= user.walletBalance ? user.walletBalance.toFixed(2)
                                            : '0.00' %></strong></span>
                            </div>
                        </div>

                        <% if (user.walletBalance < 100) { %>
                            <div class="alert alert-warning mt-3">
                                <i class="fas fa-exclamation-triangle"></i>
                                Low balance! Please <a href="/wallet">add funds</a> to play.
                            </div>
                            <% } %>
                    </div>

                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">
                            Cancel
                        </button>
                        <button type="submit" class="btn btn-primary" <%=user.walletBalance < 100 ? 'disabled' : '' %>>
                            <i class="fas fa-play"></i> Create Game
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <script>
        function showCreateModal(amount) {
            document.getElementById('modalBetAmount').value = amount;
            document.getElementById('modalAmountDisplay').innerText = '₹' + amount.toLocaleString();

            var winAmount = amount * 2;
            document.getElementById('modalWinDisplay').innerText = '₹' + winAmount.toLocaleString();

            var modal = new bootstrap.Modal(document.getElementById('createGameModal'));
            modal.show();
        }

        function validateRoomId() {
            var roomId = document.getElementById('roomId').value;
            if (!/^\d{6}$/.test(roomId)) {
                Swal.fire({
                    icon: 'error',
                    title: 'Invalid Room ID',
                    text: 'Please enter a valid 6-digit room ID',
                    background: 'var(--bg-nav)',
                    color: 'var(--text-main)',
                    confirmButtonColor: 'var(--primary)'
                });
                return false;
            }
            return true;
        }

        function showSupport() {
            Swal.fire({
                icon: 'info',
                title: 'Support',
                text: 'Live chat coming soon! Please contact support@ludowin.com',
                background: 'var(--bg-nav)',
                color: 'var(--text-main)',
                confirmButtonColor: 'var(--primary)'
            });
        }

        // Auto-refresh waiting games every 30 seconds
        setTimeout(function () {
            location.reload();
        }, 30000);
    </script>

    <%- include('../partials/footer') %>