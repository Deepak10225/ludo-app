<%- include('../partials/header') %>

    <div class="profile-container">
        <div class="container">
            <!-- Profile Header -->
            <div class="profile-header">
                <div class="row align-items-center">
                    <div class="col-md-8">
                        <h1 class="profile-title">
                            <i class="fas fa-user-circle"></i> My Profile
                        </h1>
                        <p class="profile-subtitle">Manage your account information</p>
                    </div>
                    <div class="col-md-4 text-md-end">
                        <button class="btn btn-primary" onclick="toggleEditMode()" id="editBtn">
                            <i class="fas fa-edit"></i> Edit Profile
                        </button>
                    </div>
                </div>
            </div>

            <!-- Profile Content -->
            <div class="row">
                <!-- Left Column - Profile Card -->
                <div class="col-lg-4">
                    <div class="profile-card">
                        <div class="profile-avatar-section">
                            <div class="avatar-wrapper">
                                <div class="avatar-circle">
                                    <span class="avatar-initials">
                                        <%= user.username ? user.username.charAt(0).toUpperCase() : 'U' %>
                                    </span>
                                </div>
                                <div class="avatar-status <%= user.isActive ? 'active' : 'inactive' %>"></div>
                            </div>
                            <h3 class="profile-name">
                                <%= user.fullName || user.username %>
                            </h3>
                            <p class="profile-username">@<%= user.username %>
                            </p>
                            <p class="profile-joined">Member since <%= new
                                    Date(user.createdAt).toLocaleDateString('en-IN', { month: 'long' , year: 'numeric'
                                    }) %>
                            </p>
                        </div>

                        <div class="profile-stats">
                            <div class="stat-item">
                                <div class="stat-value">
                                    <%= user.totalGames || 0 %>
                                </div>
                                <div class="stat-label">Games Played</div>
                            </div>
                            <div class="stat-item">
                                <div class="stat-value">
                                    <%= user.totalWins || 0 %>
                                </div>
                                <div class="stat-label">Wins</div>
                            </div>
                            <div class="stat-item">
                                <div class="stat-value">
                                    <%= user.totalWins && user.totalGames ? Math.round((user.totalWins /
                                        user.totalGames) * 100) : 0 %>%
                                </div>
                                <div class="stat-label">Win Rate</div>
                            </div>
                        </div>

                        <div class="profile-wallet-info">
                            <div class="wallet-item">
                                <i class="fas fa-wallet"></i>
                                <div>
                                    <span class="label">Wallet Balance</span>
                                    <span class="value">₹<%= user.walletBalance.toFixed(2) %></span>
                                </div>
                            </div>
                            <div class="wallet-item">
                                <i class="fas fa-trophy"></i>
                                <div>
                                    <span class="label">Total Earnings</span>
                                    <span class="value">₹<%= (user.totalEarnings || 0).toFixed(2) %></span>
                                </div>
                            </div>
                        </div>

                        <div class="profile-actions">
                            <a href="/wallet" class="action-btn">
                                <i class="fas fa-wallet"></i>
                                <span>Go to Wallet</span>
                            </a>
                            <a href="/games/history/all" class="action-btn">
                                <i class="fas fa-history"></i>
                                <span>Game History</span>
                            </a>
                        </div>
                    </div>
                </div>

                <!-- Right Column - Profile Details -->
                <div class="col-lg-8">
                    <!-- View Mode -->
                    <div class="details-card" id="viewMode">
                        <div class="details-header">
                            <h4>Personal Information</h4>
                        </div>

                        <div class="details-grid">
                            <div class="detail-item">
                                <div class="detail-label">Full Name</div>
                                <div class="detail-value">
                                    <%= user.fullName || 'Not provided' %>
                                </div>
                            </div>

                            <div class="detail-item">
                                <div class="detail-label">Username</div>
                                <div class="detail-value">
                                    <%= user.username %>
                                </div>
                            </div>

                            <div class="detail-item">
                                <div class="detail-label">Email Address</div>
                                <div class="detail-value">
                                    <%= user.email %>
                                </div>
                            </div>

                            <div class="detail-item">
                                <div class="detail-label">Phone Number</div>
                                <div class="detail-value">
                                    <%= user.phoneNumber || 'Not provided' %>
                                </div>
                            </div>

                            <div class="detail-item">
                                <div class="detail-label">Date of Birth</div>
                                <div class="detail-value">
                                    <%= user.dob ? new Date(user.dob).toLocaleDateString('en-IN', { day: 'numeric' ,
                                        month: 'long' , year: 'numeric' }) : 'Not provided' %>
                                </div>
                            </div>

                            <div class="detail-item">
                                <div class="detail-label">Gender</div>
                                <div class="detail-value">
                                    <%= user.gender ? user.gender.charAt(0).toUpperCase() + user.gender.slice(1)
                                        : 'Not provided' %>
                                </div>
                            </div>

                            <div class="detail-item">
                                <div class="detail-label">Referral Code</div>
                                <div class="detail-value referral-code-display">
                                    <code><%= user.referralCode || 'LUDO' + (user._id ? user._id.toString().slice(-6) : '123456') %></code>
                                    <button class="btn-copy" onclick="copyReferralCode()">
                                        <i class="fas fa-copy"></i>
                                    </button>
                                </div>
                            </div>

                            <div class="detail-item">
                                <div class="detail-label">Account Status</div>
                                <div class="detail-value">
                                    <span class="status-badge <%= user.isActive ? 'active' : 'inactive' %>">
                                        <%= user.isActive ? 'Active' : 'Inactive' %>
                                    </span>
                                    <% if (user.isAdmin) { %>
                                        <span class="status-badge admin">Admin</span>
                                        <% } %>
                                </div>
                            </div>
                        </div>

                        <div class="security-section">
                            <h4>Security</h4>
                            <div class="security-item">
                                <div class="security-info">
                                    <i class="fas fa-lock"></i>
                                    <div>
                                        <strong>Password</strong>
                                        <p>Last changed: Never</p>
                                    </div>
                                </div>
                                <button class="btn btn-outline-primary btn-sm" onclick="showChangePassword()">
                                    Change Password
                                </button>
                            </div>

                            <div class="security-item">
                                <div class="security-info">
                                    <i class="fas fa-shield-alt"></i>
                                    <div>
                                        <strong>Two-Factor Authentication</strong>
                                        <p>Enhance your account security</p>
                                    </div>
                                </div>
                                <button class="btn btn-outline-primary btn-sm" onclick="show2FA()">
                                    Enable
                                </button>
                            </div>
                        </div>
                    </div>

                    <!-- Edit Mode -->
                    <div class="details-card" id="editMode" style="display: none;">
                        <div class="details-header">
                            <h4>Edit Profile</h4>
                            <button class="btn-close" onclick="toggleEditMode()"></button>
                        </div>

                        <form action="/profile" method="POST" class="edit-form" onsubmit="return validateProfileForm()">
                            <div class="form-row">
                                <div class="form-group">
                                    <label for="fullName">Full Name</label>
                                    <input type="text" class="form-control" id="fullName" name="fullName"
                                        value="<%= user.fullName || '' %>" placeholder="Enter your full name">
                                </div>

                                <div class="form-group">
                                    <label for="username">Username</label>
                                    <input type="text" class="form-control" id="username" name="username"
                                        value="<%= user.username %>" placeholder="Username" required minlength="3">
                                    <small class="text-muted">Minimum 3 characters</small>
                                </div>
                            </div>

                            <div class="form-row">
                                <div class="form-group">
                                    <label for="email">Email Address</label>
                                    <input type="email" class="form-control" id="email" value="<%= user.email %>"
                                        disabled readonly>
                                    <small class="text-muted">Email cannot be changed</small>
                                </div>

                                <div class="form-group">
                                    <label for="phoneNumber">Phone Number</label>
                                    <input type="tel" class="form-control" id="phoneNumber" name="phoneNumber"
                                        value="<%= user.phoneNumber || '' %>" placeholder="10 digit mobile number"
                                        pattern="[0-9]{10}">
                                </div>
                            </div>

                            <div class="form-row">
                                <div class="form-group">
                                    <label for="dob">Date of Birth</label>
                                    <input type="date" class="form-control" id="dob" name="dob"
                                        value="<%= user.dob ? new Date(user.dob).toISOString().split('T')[0] : '' %>">
                                </div>

                                <div class="form-group">
                                    <label for="gender">Gender</label>
                                    <select class="form-control" id="gender" name="gender">
                                        <option value="">Select gender</option>
                                        <option value="male" <%=user.gender==='male' ? 'selected' : '' %>>Male</option>
                                        <option value="female" <%=user.gender==='female' ? 'selected' : '' %>>Female
                                        </option>
                                        <option value="other" <%=user.gender==='other' ? 'selected' : '' %>>Other
                                        </option>
                                    </select>
                                </div>
                            </div>

                            <div class="form-actions">
                                <button type="button" class="btn btn-secondary" onclick="toggleEditMode()">
                                    Cancel
                                </button>
                                <button type="submit" class="btn btn-primary">
                                    <i class="fas fa-save"></i> Save Changes
                                </button>
                            </div>
                        </form>
                    </div>

                    <!-- Change Password Modal -->
                    <div class="modal fade" id="passwordModal" tabindex="-1">
                        <div class="modal-dialog">
                            <div class="modal-content">
                                <div class="modal-header">
                                    <h5 class="modal-title">Change Password</h5>
                                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                                </div>
                                <div class="modal-body">
                                    <form action="/change-password" method="POST" id="passwordForm"
                                        onsubmit="return validatePasswordForm()">
                                        <div class="form-group">
                                            <label for="currentPassword">Current Password</label>
                                            <div class="password-field">
                                                <input type="password" class="form-control" id="currentPassword"
                                                    name="currentPassword" required>
                                                <button type="button" class="password-toggle"
                                                    onclick="togglePasswordField('currentPassword', this)">
                                                    <i class="fas fa-eye"></i>
                                                </button>
                                            </div>
                                        </div>

                                        <div class="form-group">
                                            <label for="newPassword">New Password</label>
                                            <div class="password-field">
                                                <input type="password" class="form-control" id="newPassword"
                                                    name="newPassword" minlength="6" required>
                                                <button type="button" class="password-toggle"
                                                    onclick="togglePasswordField('newPassword', this)">
                                                    <i class="fas fa-eye"></i>
                                                </button>
                                            </div>
                                            <div class="password-strength mt-2">
                                                <div class="strength-bar"></div>
                                            </div>
                                            <small class="text-muted">Minimum 6 characters</small>
                                        </div>

                                        <div class="form-group">
                                            <label for="confirmPassword">Confirm New Password</label>
                                            <div class="password-field">
                                                <input type="password" class="form-control" id="confirmPassword"
                                                    minlength="6" required>
                                                <button type="button" class="password-toggle"
                                                    onclick="togglePasswordField('confirmPassword', this)">
                                                    <i class="fas fa-eye"></i>
                                                </button>
                                            </div>
                                            <div class="password-match-message"></div>
                                        </div>

                                        <div class="modal-footer px-0 pb-0">
                                            <button type="button" class="btn btn-secondary"
                                                data-bs-dismiss="modal">Cancel</button>
                                            <button type="submit" class="btn btn-primary">Update Password</button>
                                        </div>
                                    </form>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <style>
        /* Profile Container */
        .profile-container {
            padding: 40px 0;
            background: #f8f9fc;
            min-height: calc(100vh - 76px);
        }

        /* Profile Header */
        .profile-header {
            margin-bottom: 30px;
        }

        .profile-title {
            font-size: 2rem;
            font-weight: 700;
            color: #333;
            margin-bottom: 10px;
        }

        .profile-title i {
            color: #667eea;
        }

        .profile-subtitle {
            color: #666;
            font-size: 1.1rem;
        }

        /* Profile Card */
        .profile-card {
            background: white;
            border-radius: 20px;
            padding: 30px;
            box-shadow: 0 10px 30px rgba(0, 0, 0, 0.08);
            margin-bottom: 30px;
        }

        /* Avatar Section */
        .profile-avatar-section {
            text-align: center;
            margin-bottom: 25px;
        }

        .avatar-wrapper {
            position: relative;
            display: inline-block;
            margin-bottom: 15px;
        }

        .avatar-circle {
            width: 120px;
            height: 120px;
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            border: 4px solid white;
            box-shadow: 0 10px 20px rgba(102, 126, 234, 0.3);
        }

        .avatar-initials {
            font-size: 3.5rem;
            font-weight: 700;
            color: white;
            text-transform: uppercase;
        }

        .avatar-status {
            position: absolute;
            bottom: 10px;
            right: 10px;
            width: 20px;
            height: 20px;
            border-radius: 50%;
            border: 3px solid white;
        }

        .avatar-status.active {
            background: #1cc88a;
        }

        .avatar-status.inactive {
            background: #e74a3b;
        }

        .profile-name {
            font-size: 1.5rem;
            font-weight: 700;
            color: #333;
            margin-bottom: 5px;
        }

        .profile-username {
            color: #667eea;
            font-size: 1rem;
            margin-bottom: 5px;
        }

        .profile-joined {
            color: #999;
            font-size: 0.9rem;
        }

        /* Profile Stats */
        .profile-stats {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 15px;
            padding: 20px 0;
            border-top: 1px solid #e0e0e0;
            border-bottom: 1px solid #e0e0e0;
            margin-bottom: 20px;
            text-align: center;
        }

        .stat-value {
            font-size: 1.5rem;
            font-weight: 700;
            color: #333;
            margin-bottom: 5px;
        }

        .stat-label {
            font-size: 0.85rem;
            color: #999;
        }

        /* Wallet Info */
        .profile-wallet-info {
            margin-bottom: 20px;
        }

        .wallet-item {
            display: flex;
            align-items: center;
            gap: 15px;
            padding: 12px;
            background: #f8f9fc;
            border-radius: 12px;
            margin-bottom: 10px;
        }

        .wallet-item i {
            width: 40px;
            height: 40px;
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            border-radius: 10px;
            display: flex;
            align-items: center;
            justify-content: center;
            color: white;
            font-size: 1.2rem;
        }

        .wallet-item .label {
            display: block;
            font-size: 0.85rem;
            color: #999;
            margin-bottom: 3px;
        }

        .wallet-item .value {
            display: block;
            font-size: 1.2rem;
            font-weight: 700;
            color: #333;
        }

        /* Profile Actions */
        .profile-actions {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 10px;
        }

        .action-btn {
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 8px;
            padding: 12px;
            background: #f8f9fc;
            border-radius: 10px;
            color: #333;
            text-decoration: none;
            transition: all 0.3s ease;
        }

        .action-btn:hover {
            background: #667eea;
            color: white;
            transform: translateY(-2px);
        }

        .action-btn i {
            font-size: 1rem;
        }

        /* Details Card */
        .details-card {
            background: white;
            border-radius: 20px;
            padding: 30px;
            box-shadow: 0 10px 30px rgba(0, 0, 0, 0.08);
            margin-bottom: 30px;
        }

        .details-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 25px;
        }

        .details-header h4 {
            font-size: 1.2rem;
            font-weight: 600;
            color: #333;
            margin: 0;
        }

        /* Details Grid */
        .details-grid {
            display: grid;
            grid-template-columns: repeat(2, 1fr);
            gap: 20px;
            margin-bottom: 30px;
        }

        .detail-item {
            padding: 15px;
            background: #f8f9fc;
            border-radius: 12px;
        }

        .detail-label {
            font-size: 0.85rem;
            color: #999;
            margin-bottom: 5px;
        }

        .detail-value {
            font-size: 1rem;
            font-weight: 500;
            color: #333;
        }

        .referral-code-display {
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .referral-code-display code {
            background: white;
            padding: 5px 10px;
            border-radius: 5px;
            font-size: 1rem;
            color: #667eea;
        }

        .btn-copy {
            background: none;
            border: none;
            color: #667eea;
            cursor: pointer;
            transition: color 0.3s ease;
        }

        .btn-copy:hover {
            color: #764ba2;
        }

        /* Status Badge */
        .status-badge {
            display: inline-block;
            padding: 4px 12px;
            border-radius: 50px;
            font-size: 0.8rem;
            font-weight: 500;
            text-transform: capitalize;
            margin-right: 8px;
        }

        .status-badge.active {
            background: rgba(28, 200, 138, 0.1);
            color: #1cc88a;
        }

        .status-badge.inactive {
            background: rgba(231, 74, 59, 0.1);
            color: #e74a3b;
        }

        .status-badge.admin {
            background: rgba(102, 126, 234, 0.1);
            color: #667eea;
        }

        /* Security Section */
        .security-section {
            border-top: 1px solid #e0e0e0;
            padding-top: 25px;
        }

        .security-section h4 {
            font-size: 1.1rem;
            font-weight: 600;
            color: #333;
            margin-bottom: 20px;
        }

        .security-item {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 15px;
            background: #f8f9fc;
            border-radius: 12px;
            margin-bottom: 10px;
        }

        .security-info {
            display: flex;
            align-items: center;
            gap: 15px;
        }

        .security-info i {
            width: 40px;
            height: 40px;
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            border-radius: 10px;
            display: flex;
            align-items: center;
            justify-content: center;
            color: white;
            font-size: 1.2rem;
        }

        .security-info strong {
            display: block;
            font-size: 1rem;
            color: #333;
            margin-bottom: 3px;
        }

        .security-info p {
            font-size: 0.85rem;
            color: #999;
            margin: 0;
        }

        /* Edit Form */
        .edit-form {
            max-width: 100%;
        }

        .form-row {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 20px;
            margin-bottom: 20px;
        }

        .form-group {
            margin-bottom: 20px;
        }

        .form-group label {
            display: block;
            margin-bottom: 8px;
            color: #555;
            font-weight: 500;
            font-size: 0.95rem;
        }

        .form-control {
            width: 100%;
            padding: 12px 15px;
            border: 2px solid #e0e0e0;
            border-radius: 10px;
            font-size: 0.95rem;
            transition: all 0.3s ease;
            background: #f8f9fc;
        }

        .form-control:focus {
            border-color: #667eea;
            outline: none;
            background: white;
            box-shadow: 0 5px 15px rgba(102, 126, 234, 0.1);
        }

        .form-control:disabled {
            background: #f0f0f0;
            color: #999;
            cursor: not-allowed;
        }

        .form-actions {
            display: flex;
            gap: 15px;
            justify-content: flex-end;
            margin-top: 20px;
        }

        /* Password Field */
        .password-field {
            position: relative;
        }

        .password-field input {
            padding-right: 45px;
        }

        .password-toggle {
            position: absolute;
            right: 12px;
            top: 50%;
            transform: translateY(-50%);
            background: none;
            border: none;
            color: #999;
            cursor: pointer;
            padding: 5px;
            font-size: 1.1rem;
            transition: color 0.3s ease;
        }

        .password-toggle:hover {
            color: #667eea;
        }

        /* Password Strength */
        .password-strength {
            height: 4px;
            background: #e0e0e0;
            border-radius: 2px;
            overflow: hidden;
        }

        .strength-bar {
            height: 100%;
            width: 0;
            background: linear-gradient(90deg, #e74a3b, #f6c23e, #1cc88a);
            transition: width 0.3s ease;
        }

        .password-match-message {
            font-size: 0.8rem;
            margin-top: 5px;
            min-height: 20px;
        }

        .password-match-message.valid {
            color: #1cc88a;
        }

        .password-match-message.invalid {
            color: #e74a3b;
        }

        /* Responsive */
        @media (max-width: 768px) {
            .details-grid {
                grid-template-columns: 1fr;
            }

            .form-row {
                grid-template-columns: 1fr;
                gap: 0;
            }

            .profile-actions {
                grid-template-columns: 1fr;
            }

            .security-item {
                flex-direction: column;
                align-items: flex-start;
                gap: 15px;
            }

            .security-item .btn {
                width: 100%;
            }
        }

        @media (max-width: 576px) {
            .profile-card {
                padding: 20px;
            }

            .avatar-circle {
                width: 100px;
                height: 100px;
            }

            .avatar-initials {
                font-size: 3rem;
            }
        }
    </style>

    <script>
        let editMode = false;

        function toggleEditMode() {
            editMode = !editMode;
            document.getElementById('viewMode').style.display = editMode ? 'none' : 'block';
            document.getElementById('editMode').style.display = editMode ? 'block' : 'none';
            document.getElementById('editBtn').innerHTML = editMode ?
                '<i class="fas fa-times"></i> Cancel' :
                '<i class="fas fa-edit"></i> Edit Profile';
        }

        function copyReferralCode() {
            const code = document.querySelector('.referral-code-display code').innerText;
            navigator.clipboard.writeText(code).then(() => {
                alert('Referral code copied to clipboard!');
            });
        }

        function showChangePassword() {
            new bootstrap.Modal(document.getElementById('passwordModal')).show();
        }

        function show2FA() {
            alert('Two-factor authentication coming soon!');
        }

        function togglePasswordField(fieldId, button) {
            const field = document.getElementById(fieldId);
            const icon = button.querySelector('i');

            if (field.type === 'password') {
                field.type = 'text';
                icon.classList.remove('fa-eye');
                icon.classList.add('fa-eye-slash');
            } else {
                field.type = 'password';
                icon.classList.remove('fa-eye-slash');
                icon.classList.add('fa-eye');
            }
        }

        // Password strength checker
        document.getElementById('newPassword')?.addEventListener('input', function () {
            const password = this.value;
            const strengthBar = document.querySelector('.strength-bar');
            let strength = 0;

            if (password.length >= 6) strength += 25;
            if (password.match(/[a-z]+/)) strength += 25;
            if (password.match(/[A-Z]+/)) strength += 25;
            if (password.match(/[0-9]+/)) strength += 25;

            strengthBar.style.width = strength + '%';
        });

        // Password match checker
        document.getElementById('confirmPassword')?.addEventListener('input', function () {
            const password = document.getElementById('newPassword').value;
            const confirm = this.value;
            const messageDiv = document.querySelector('.password-match-message');

            if (confirm.length > 0) {
                if (password === confirm) {
                    messageDiv.textContent = '✓ Passwords match';
                    messageDiv.className = 'password-match-message valid';
                } else {
                    messageDiv.textContent = '✗ Passwords do not match';
                    messageDiv.className = 'password-match-message invalid';
                }
            } else {
                messageDiv.textContent = '';
            }
        });

        function validateProfileForm() {
            const username = document.getElementById('username').value;
            const phone = document.getElementById('phoneNumber').value;

            if (username.length < 3) {
                alert('Username must be at least 3 characters');
                return false;
            }

            if (phone && phone.length !== 10) {
                alert('Please enter a valid 10-digit phone number');
                return false;
            }

            return true;
        }

        function validatePasswordForm() {
            const current = document.getElementById('currentPassword').value;
            const newPass = document.getElementById('newPassword').value;
            const confirm = document.getElementById('confirmPassword').value;

            if (!current || !newPass || !confirm) {
                alert('Please fill all fields');
                return false;
            }

            if (newPass.length < 6) {
                alert('New password must be at least 6 characters');
                return false;
            }

            if (newPass !== confirm) {
                alert('Passwords do not match');
                return false;
            }

            return confirm('Are you sure you want to change your password?');
        }
    </script>

