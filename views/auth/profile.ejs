<%- include('../partials/header') %>

<div class="profile-container" style="min-height: 100vh; padding: 100px 0; position: relative;">
    <div class="hero-bg"></div>
    <div class="container">
        <!-- Profile Header -->
        <div class="row align-items-center mb-5" data-aos="fade-down">
            <div class="col-md-8">
                <h1 class="fw-bold text-white mb-2">
                    <i class="fas fa-user-circle text-gradient"></i> My Profile
                </h1>
                <p class="text-muted fs-5">Manage your account information</p>
            </div>
            <div class="col-md-4 text-md-end mt-3 mt-md-0">
                <button class="btn btn-primary" onclick="toggleEditMode()" id="editBtn">
                    <i class="fas fa-edit me-2"></i> Edit Profile
                </button>
            </div>
        </div>

        <div class="row g-4">
            <!-- Left Column - Profile Card -->
            <div class="col-lg-4" data-aos="fade-right">
                <div class="glass-card p-4 text-center">
                    <div class="position-relative d-inline-block mb-3">
                        <div style="width: 120px; height: 120px; border-radius: 50%; overflow: hidden; border: 4px solid var(--border-glass); box-shadow: var(--shadow-glow);">
                            <img src="<%= user.avatar || '/images/default-avatar.png' %>" alt="Avatar" style="width: 100%; height: 100%; object-fit: cover;">
                        </div>
                        <label for="avatarInput" class="position-absolute bottom-0 end-0 bg-primary text-white rounded-circle p-2 cursor-pointer shadow-lg" style="width: 35px; height: 35px; display: flex; align-items: center; justify-content: center; transform: translate(5px, 5px);">
                            <i class="fas fa-camera fa-xs"></i>
                        </label>
                        <form id="avatarForm" action="/profile/avatar" method="POST" enctype="multipart/form-data" style="display: none;">
                            <input type="file" id="avatarInput" name="avatar" onchange="document.getElementById('avatarForm').submit()">
                        </form>
                    </div>
                    
                    <h3 class="text-white fw-bold mb-1"><%= user.fullName || user.username %></h3>
                    <p class="text-gradient mb-1">@<%= user.username %></p>
                    <p class="text-muted small mb-4">Member since <%= new Date(user.createdAt).toLocaleDateString('en-IN', { month: 'long', year: 'numeric' }) %></p>

                    <div class="row g-2 mb-4 pb-4 border-bottom" style="border-color: var(--border-glass-light) !important;">
                        <div class="col-4">
                            <div class="fw-bold text-white fs-4"><%= user.totalGames || 0 %></div>
                            <div class="text-muted small">Games</div>
                        </div>
                        <div class="col-4 border-start border-end" style="border-color: var(--border-glass-light) !important;">
                            <div class="fw-bold text-white fs-4"><%= user.totalWins || 0 %></div>
                            <div class="text-muted small">Wins</div>
                        </div>
                        <div class="col-4">
                            <div class="fw-bold text-white fs-4"><%= user.totalWins && user.totalGames ? Math.round((user.totalWins / user.totalGames) * 100) : 0 %>%</div>
                            <div class="text-muted small">Win Rate</div>
                        </div>
                    </div>

                    <div class="mb-4 text-start">
                        <!-- XP & Level Progress -->
                        <div class="p-3 mb-3 rounded" style="background: rgba(255,255,255,0.05);">
                            <div class="d-flex justify-content-between align-items-center mb-2">
                                <span class="text-white fw-bold">Level <%= user.level %></span>
                                <span class="text-muted small"><%= user.xp %> / <%= user.level * 500 %> XP</span>
                            </div>
                            <div class="progress" style="height: 8px; background: rgba(0,0,0,0.3);">
                                <div id="xpProgressBar" class="progress-bar bg-primary" role="progressbar"></div>
                            </div>
                        </div>

                        <div class="d-flex align-items-center gap-3 p-3 mb-2 rounded" style="background: rgba(255,255,255,0.05);">
                            <div class="bg-primary bg-gradient rounded p-2 text-white"><i class="fas fa-wallet fa-fw"></i></div>
                            <div>
                                <div class="text-muted small">Wallet Balance</div>
                                <div class="text-white fw-bold fs-5">₹<%= user.walletBalance.toFixed(2) %></div>
                            </div>
                        </div>
                        <div class="d-flex align-items-center gap-3 p-3 rounded" style="background: rgba(255,255,255,0.05);">
                            <div class="bg-warning bg-gradient rounded p-2 text-dark"><i class="fas fa-trophy fa-fw"></i></div>
                            <div>
                                <div class="text-muted small">Total Earnings</div>
                                <div class="text-white fw-bold fs-5">₹<%= (user.totalEarnings || 0).toFixed(2) %></div>
                            </div>
                        </div>
                    </div>

                    <!-- Badges Section -->
                    <% if (user.badges && user.badges.length > 0) { %>
                        <div class="mb-4 text-start">
                            <label class="text-muted small mb-2 d-block">Achievements</label>
                            <div class="d-flex flex-wrap gap-2">
                                <% user.badges.forEach(badge => { %>
                                    <span class="badge rounded-pill bg-dark border border-secondary p-2 px-3">
                                        <i class="fas fa-award text-warning me-1"></i> <%= badge %>
                                    </span>
                                <% }) %>
                            </div>
                        </div>
                    <% } %>

                    <div class="d-grid gap-2">
                        <a href="/wallet" class="btn btn-outline-light"><i class="fas fa-wallet me-2"></i>Go to Wallet</a>
                        <a href="/games/history/all" class="btn btn-outline-light"><i class="fas fa-history me-2"></i>Game History</a>
                    </div>
                </div>
            </div>

            <!-- Right Column - Profile Details -->
            <div class="col-lg-8" data-aos="fade-left">
                <!-- View Mode -->
                <div class="glass-card p-4 mb-4" id="viewMode">
                    <h4 class="text-white border-bottom pb-3 mb-4" style="border-color: var(--border-glass-light) !important;">Personal Information</h4>
                    
                    <div class="row g-4 mb-4">
                        <div class="col-sm-6">
                            <div class="p-3 rounded" style="background: rgba(255,255,255,0.03); border: 1px solid var(--border-glass);">
                                <div class="text-muted small mb-1">Full Name</div>
                                <div class="text-white fw-bold"><%= user.fullName || 'Not provided' %></div>
                            </div>
                        </div>
                        <div class="col-sm-6">
                            <div class="p-3 rounded" style="background: rgba(255,255,255,0.03); border: 1px solid var(--border-glass);">
                                <div class="text-muted small mb-1">Username</div>
                                <div class="text-white fw-bold">@<%= user.username %></div>
                            </div>
                        </div>
                        <div class="col-sm-6">
                            <div class="p-3 rounded" style="background: rgba(255,255,255,0.03); border: 1px solid var(--border-glass);">
                                <div class="text-muted small mb-1">Email Address</div>
                                <div class="text-white fw-bold"><%= user.email %></div>
                            </div>
                        </div>
                        <div class="col-sm-6">
                            <div class="p-3 rounded" style="background: rgba(255,255,255,0.03); border: 1px solid var(--border-glass);">
                                <div class="text-muted small mb-1">Phone Number</div>
                                <div class="text-white fw-bold"><%= user.phoneNumber || 'Not provided' %></div>
                            </div>
                        </div>
                        <div class="col-sm-6">
                            <div class="p-3 rounded" style="background: rgba(255,255,255,0.03); border: 1px solid var(--border-glass);">
                                <div class="text-muted small mb-1">Date of Birth</div>
                                <div class="text-white fw-bold"><%= user.dob ? new Date(user.dob).toLocaleDateString('en-IN', { day: 'numeric', month: 'long', year: 'numeric' }) : 'Not provided' %></div>
                            </div>
                        </div>
                        <div class="col-sm-6">
                            <div class="p-3 rounded" style="background: rgba(255,255,255,0.03); border: 1px solid var(--border-glass);">
                                <div class="text-muted small mb-1">Referral Code</div>
                                <div class="d-flex align-items-center justify-content-between">
                                    <code class="text-primary fs-5"><%= user.referralCode || 'LUDO' + (user._id ? user._id.toString().slice(-6) : '123456') %></code>
                                    <button class="btn btn-sm btn-outline-light border-0" onclick="copyReferralCode()"><i class="fas fa-copy"></i></button>
                                </div>
                            </div>
                        </div>
                    </div>

                    <h4 class="text-white border-bottom pb-3 mb-4 mt-5" style="border-color: var(--border-glass-light) !important;">Security</h4>
                    <div class="d-flex justify-content-between align-items-center p-3 rounded mb-3" style="background: rgba(255,255,255,0.03); border: 1px solid var(--border-glass);">
                        <div class="d-flex align-items-center gap-3">
                            <div class="bg-primary bg-gradient rounded p-2 text-white"><i class="fas fa-lock fa-fw"></i></div>
                            <div>
                                <div class="text-white fw-bold">Password</div>
                                <div class="text-muted small">Update your password to keep your account secure</div>
                            </div>
                        </div>
                        <button class="btn btn-outline-light btn-sm" onclick="showChangePassword()">Change Password</button>
                    </div>
                </div>

                <!-- Edit Mode Form (Hidden by default) -->
                <div class="glass-card p-4 mb-4" id="editMode" style="display: none;">
                    <div class="d-flex justify-content-between border-bottom pb-3 mb-4" style="border-color: var(--border-glass-light) !important;">
                        <h4 class="text-white mb-0">Edit Profile</h4>
                        <button class="btn-close btn-close-white" onclick="toggleEditMode()"></button>
                    </div>

                    <form action="/profile" method="POST">
                        <div class="row g-4 mb-4">
                            <div class="col-md-6">
                                <label class="form-label text-muted">Full Name</label>
                                <input type="text" class="form-control" name="fullName" value="<%= user.fullName || '' %>" placeholder="Enter your full name">
                            </div>
                            <div class="col-md-6">
                                <label class="form-label text-muted">Username</label>
                                <input type="text" class="form-control" name="username" value="<%= user.username %>" placeholder="Username" required minlength="3">
                            </div>
                            <div class="col-md-6">
                                <label class="form-label text-muted">Email Address</label>
                                <input type="email" class="form-control" value="<%= user.email %>" disabled readonly>
                            </div>
                            <div class="col-md-6">
                                <label class="form-label text-muted">Phone Number</label>
                                <input type="tel" class="form-control" name="phoneNumber" value="<%= user.phoneNumber || '' %>" placeholder="10 digit number" pattern="[0-9]{10}">
                            </div>
                            <div class="col-md-6">
                                <label class="form-label text-muted">Date of Birth</label>
                                <input type="date" class="form-control" name="dob" value="<%= user.dob ? new Date(user.dob).toISOString().split('T')[0] : '' %>">
                            </div>
                            <div class="col-md-6">
                                <label class="form-label text-muted">Gender</label>
                                <select class="form-select bg-dark text-white border-secondary" name="gender">
                                    <option value="">Select gender</option>
                                    <option value="male" <%= user.gender === 'male' ? 'selected' : '' %>>Male</option>
                                    <option value="female" <%= user.gender === 'female' ? 'selected' : '' %>>Female</option>
                                    <option value="other" <%= user.gender === 'other' ? 'selected' : '' %>>Other</option>
                                </select>
                            </div>
                        </div>
                        <div class="d-flex justify-content-end gap-2">
                            <button type="button" class="btn btn-outline-light" onclick="toggleEditMode()">Cancel</button>
                            <button type="submit" class="btn btn-primary"><i class="fas fa-save me-2"></i>Save Changes</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
    document.addEventListener('DOMContentLoaded', function() {
        // Set XP progress bar width
        const xpProgress = document.getElementById('xpProgressBar');
        if (xpProgress) {
            const currentXp = parseInt("<%= user.xp %>") || 0;
            const currentLevel = parseInt("<%= user.level %>") || 1;
            const progress = (currentXp % 500) / 5;
            xpProgress.style.width = progress + '%';
        }
    });

    function toggleEditMode() {
        const viewMode = document.getElementById('viewMode');
        const editMode = document.getElementById('editMode');
        const editBtn = document.getElementById('editBtn');
        
        if (viewMode.style.display === 'none') {
            viewMode.style.display = 'block';
            editMode.style.display = 'none';
            editBtn.style.display = 'inline-block';
        } else {
            viewMode.style.display = 'none';
            editMode.style.display = 'block';
            editBtn.style.display = 'none';
        }
    }

    function showChangePassword() {
        // Implement modal or inline change password flow
        alert("Change password flow would go here");
    }

    function copyReferralCode() {
        const code = "<%= user.referralCode || 'LUDO' + (user._id ? user._id.toString().slice(-6) : '123456') %>";
        navigator.clipboard.writeText(code).then(() => {
            alert("Referral code copied to clipboard!");
        });
    }
</script>

<%- include('../partials/footer') %>