<%- include('../partials/header') %>

<div class="login-container" style="min-height: 100vh; padding: 100px 0; position: relative;">
    <div class="hero-bg"></div>
    <div class="container">
        <div class="row align-items-center justify-content-center">
            <!-- Left Side - Branding -->
            <div class="col-lg-5 d-none d-lg-block" data-aos="fade-right">
                <div class="login-brand text-center mb-5">
                    <i class="fas fa-dice fa-5x mb-4 text-gradient"></i>
                    <h2 class="text-white fw-bold display-5">Welcome Back!</h2>
                    <p class="text-muted fs-5">Continue your winning journey</p>
                </div>

                <div class="glass-card p-4 mb-4">
                    <div class="d-flex align-items-center gap-3 mb-3">
                        <div class="feature-icon" style="width: 40px; height: 40px; font-size: 1.2rem;"><i class="fas fa-shield-alt"></i></div>
                        <div>
                            <h6 class="text-white mb-0">100% Secure</h6>
                            <p class="text-muted small mb-0">Your data is protected</p>
                        </div>
                    </div>
                    <div class="d-flex align-items-center gap-3 mb-3">
                        <div class="feature-icon" style="width: 40px; height: 40px; font-size: 1.2rem;"><i class="fas fa-bolt"></i></div>
                        <div>
                            <h6 class="text-white mb-0">Instant Access</h6>
                            <p class="text-muted small mb-0">Quick & easy login</p>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Right Side - Login Form -->
            <div class="col-lg-5 col-md-8" data-aos="fade-left">
                <div class="glass-card p-5">
                    <div class="text-center mb-4">
                        <h3 class="fw-bold text-white mb-2">Sign In</h3>
                        <p class="text-muted">Don't have an account? <a href="/register" class="text-gradient fw-bold">Create one</a></p>
                    </div>

                    <form action="/login" method="POST">
                        <div class="mb-4">
                            <label class="form-label text-muted"><i class="fas fa-envelope me-2 text-primary"></i>Email Address</label>
                            <input type="email" class="form-control form-control-lg" name="email" placeholder="Enter your email" required>
                        </div>

                        <div class="mb-4">
                            <label class="form-label text-muted"><i class="fas fa-lock me-2 text-primary"></i>Password</label>
                            <input type="password" class="form-control form-control-lg" id="password" name="password" placeholder="Enter your password" required>
                        </div>

                        <div class="d-flex justify-content-between align-items-center mb-4">
                            <div class="form-check">
                                <input class="form-check-input" type="checkbox" id="remember" name="remember" style="background-color: transparent; border-color: var(--border-glass);">
                                <label class="form-check-label text-muted" for="remember">Remember me</label>
                            </div>
                            <a href="#" class="text-muted small hover-primary">Forgot password?</a>
                        </div>

                        <button type="submit" class="btn btn-primary btn-lg w-100 mb-4">
                            Sign In <i class="fas fa-arrow-right ms-2"></i>
                        </button>

                        <div class="position-relative text-center mb-4">
                            <hr style="border-color: var(--border-glass);">
                            <span class="position-absolute top-50 start-50 translate-middle px-3 text-muted" style="background: var(--bg-surface); backdrop-filter: blur(16px);">Or continue with</span>
                        </div>

                        <div class="row g-3">
                            <div class="col-6">
                                <button type="button" class="btn btn-outline-light w-100"><i class="fab fa-google text-danger me-2"></i>Google</button>
                            </div>
                            <div class="col-6">
                                <button type="button" class="btn btn-outline-light w-100"><i class="fab fa-facebook-f text-primary me-2"></i>Facebook</button>
                            </div>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

<%- include('../partials/footer') %>