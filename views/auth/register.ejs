<%- include('../partials/header') %>

<div class="register-container" style="min-height: 100vh; padding: 100px 0; position: relative;">
    <div class="hero-bg"></div>
    <div class="container">
        <div class="row align-items-center justify-content-center">
            
            <div class="col-lg-8" data-aos="zoom-in">
                <div class="glass-card p-5">
                    <div class="text-center mb-5">
                        <i class="fas fa-user-plus fa-3x mb-3 text-gradient"></i>
                        <h2 class="fw-bold text-white mb-2">Create Account</h2>
                        <p class="text-muted">Already have an account? <a href="/login" class="text-gradient fw-bold">Sign in</a></p>
                    </div>

                    <form action="/register" method="POST">
                        <div class="row g-4 mb-4">
                            <div class="col-md-6">
                                <label class="form-label text-muted"><i class="fas fa-user me-2 text-primary"></i>Username</label>
                                <input type="text" class="form-control form-control-lg" name="username" placeholder="Choose a username" minlength="3" required>
                                <small class="text-muted mt-1 d-block"><i class="fas fa-info-circle me-1"></i>Minimum 3 characters</small>
                            </div>
                            <div class="col-md-6">
                                <label class="form-label text-muted"><i class="fas fa-envelope me-2 text-primary"></i>Email Address</label>
                                <input type="email" class="form-control form-control-lg" name="email" placeholder="Enter your email" required>
                            </div>
                        </div>

                        <div class="row g-4 mb-4">
                            <div class="col-md-6">
                                <label class="form-label text-muted"><i class="fas fa-lock me-2 text-primary"></i>Password</label>
                                <input type="password" class="form-control form-control-lg" name="password" placeholder="Create password" minlength="6" required>
                                <small class="text-muted mt-1 d-block"><i class="fas fa-shield-alt me-1"></i>Minimum 6 characters</small>
                            </div>
                            <div class="col-md-6">
                                <label class="form-label text-muted"><i class="fas fa-phone me-2 text-primary"></i>Phone Number</label>
                                <input type="tel" class="form-control form-control-lg" name="phoneNumber" placeholder="10 digit mobile number" pattern="[0-9]{10}" required>
                            </div>
                        </div>

                        <div class="row g-4 mb-4">
                            <div class="col-md-6">
                                <label class="form-label text-muted"><i class="fas fa-id-card me-2 text-primary"></i>Full Name <span class="text-muted small">(Optional)</span></label>
                                <input type="text" class="form-control form-control-lg" name="fullName" placeholder="Enter your full name">
                            </div>
                            <div class="col-md-6">
                                <label class="form-label text-muted"><i class="fas fa-gift me-2 text-primary"></i>Referral Code <span class="text-muted small">(Optional)</span></label>
                                <input type="text" class="form-control form-control-lg" name="referral" placeholder="Enter referral code">
                            </div>
                        </div>

                        <div class="form-check mb-4 mt-2">
                            <input class="form-check-input" type="checkbox" id="terms" required style="background-color: transparent; border-color: var(--border-glass);">
                            <label class="form-check-label text-muted" for="terms">
                                I agree to the <a href="#" class="text-primary">Terms of Service</a> and <a href="#" class="text-primary">Privacy Policy</a>
                            </label>
                        </div>

                        <button type="submit" class="btn btn-primary btn-lg w-100">
                            Create Account <i class="fas fa-check-circle ms-2"></i>
                        </button>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

<%- include('../partials/footer') %>