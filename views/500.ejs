<%- include('partials/header') %>

    <div class="container py-5">
        <div class="row justify-content-center min-vh-75 align-items-center">
            <div class="col-md-8 text-center">
                <div class="error-icon mb-4">
                    <i class="fas fa-exclamation-triangle text-danger" style="font-size: 5rem;"></i>
                </div>

                <h1 class="display-1 fw-bold text-danger">500</h1>
                <h2 class="mb-4">Internal Server Error</h2>

                <p class="lead mb-5 text-muted">
                    Oops! Something went wrong on our end. We're working to fix it.
                    Please try again in a few moments.
                </p>

                <% if (error && process.env.NODE_ENV==='development' ) { %>
                    <div class="alert alert-danger text-start mb-4">
                        <strong class="d-block mb-2">Error Details (Development Only):</strong>
                        <pre class="mb-0"><code><%= error %></code></pre>
                    </div>
                    <% } %>

                        <div class="d-flex justify-content-center gap-3">
                            <a href="/" class="btn btn-primary btn-lg">
                                <i class="fas fa-home me-2"></i>Go to Homepage
                            </a>

                            <button onclick="location.reload()" class="btn btn-outline-secondary btn-lg">
                                <i class="fas fa-sync-alt me-2"></i>Try Again
                            </button>
                        </div>

                        <div class="mt-4">
                            <p class="text-muted">
                                Need immediate help?
                                <a href="#" class="text-primary">Contact Support</a>
                            </p>
                        </div>
            </div>
        </div>
    </div>

    <style>
        .min-vh-75 {
            min-height: 75vh;
        }

        .error-icon {
            animation: shake 0.5s ease-in-out infinite;
        }

        @keyframes shake {

            0%,
            100% {
                transform: translateX(0);
            }

            25% {
                transform: translateX(-10px);
            }

            75% {
                transform: translateX(10px);
            }
        }

        pre {
            background: #f8f9fc;
            padding: 1rem;
            border-radius: 8px;
            max-height: 200px;
            overflow: auto;
        }
    </style>

    <%- include('partials/footer') %>