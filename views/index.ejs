<%- include('partials/header') %>

    <!-- Hero Section -->
    <section class="hero-section">
        <div class="container">
            <div class="row min-vh-100 align-items-center">
                <div class="col-lg-6" data-aos="fade-right">
                    <h1 class="hero-title">
                        Play Ludo & <br>
                        <span class="text-gradient">Win Real Cash</span>
                    </h1>
                    <p class="hero-description">
                        Join India's most trusted Ludo gaming platform. Play with real players,
                        win real money, and withdraw instantly to your bank account.
                    </p>

                    <% if (!user) { %>
                        <div class="hero-buttons">
                            <!-- <a href="/register" class="btn btn-primary btn-lg">
                                <i class="fas fa-user-plus"></i> Create Account
                            </a> -->
                            <a href="/login" class="btn btn-outline-light btn-lg ms-3">
                                <i class="fas fa-sign-in-alt"></i> Login
                            </a>
                        </div>
                        <% } else { %>
                            <div class="hero-buttons">
                                <a href="/games" class="btn btn-primary btn-lg">
                                    <i class="fas fa-gamepad"></i> Start Playing
                                </a>
                                <a href="/wallet" class="btn btn-outline-light btn-lg ms-3">
                                    <i class="fas fa-wallet"></i> Add Funds
                                </a>
                            </div>
                            <% } %>

                                <!-- Stats -->
                                <div class="hero-stats mt-5">
                                    <div class="row">
                                        <div class="col-4">
                                            <h3>10K+</h3>
                                            <p>Active Players</p>
                                        </div>
                                        <div class="col-4">
                                            <h3>₹50L+</h3>
                                            <p>Total Winnings</p>
                                        </div>
                                        <div class="col-4">
                                            <h3>24/7</h3>
                                            <p>Quick Support</p>
                                        </div>
                                    </div>
                                </div>
                </div>

                <div class="col-lg-6" data-aos="fade-left">
                    <div class="hero-image">
                        <img src="https://cdn3d.iconscout.com/3d/premium/thumb/ludo-3d-icon-download-in-png-blend-fbx-gltf-file-formats--board-game-ludogame-pack-games-icons-8053419.png?f=webp"
                            alt="Ludo Game" class="img-fluid floating">

                        <!-- Floating Cards -->
                        <div class="floating-card card-1">
                            <i class="fas fa-trophy text-warning"></i>
                            <span>Win ₹10,000</span>
                        </div>
                        <div class="floating-card card-2">
                            <i class="fas fa-users text-primary"></i>
                            <span>2 Players</span>
                        </div>
                        <div class="floating-card card-3">
                            <i class="fas fa-clock text-success"></i>
                            <span>Quick Match</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Wave Divider -->
        <div class="wave-divider">
            <svg viewBox="0 0 1440 320">
                <path fill="#ffffff" fill-opacity="1"
                    d="M0,96L48,112C96,128,192,160,288,160C384,160,480,128,576,122.7C672,117,768,139,864,154.7C960,171,1056,181,1152,165.3C1248,149,1344,107,1392,85.3L1440,64L1440,320L1392,320C1344,320,1248,320,1152,320C1056,320,960,320,864,320C768,320,672,320,576,320C480,320,384,320,288,320C192,320,96,320,48,320L0,320Z">
                </path>
            </svg>
        </div>
    </section>

    <!-- Features Section -->
    <section class="features-section" id="features">
        <div class="container">
            <div class="section-header text-center" data-aos="fade-up">
                <span class="section-subtitle">WHY CHOOSE US</span>
                <h2 class="section-title">Experience the Best <span class="text-gradient">Ludo Gaming</span></h2>
                <p class="section-description">
                    We provide the most secure and exciting platform for Ludo lovers
                </p>
            </div>

            <div class="row g-4 mt-4">
                <div class="col-md-4" data-aos="fade-up" data-aos-delay="100">
                    <div class="feature-card">
                        <div class="feature-icon">
                            <i class="fas fa-shield-alt"></i>
                        </div>
                        <h4>100% Secure</h4>
                        <p>Your money is safe with our encrypted payment system and secure wallet</p>
                    </div>
                </div>

                <div class="col-md-4" data-aos="fade-up" data-aos-delay="200">
                    <div class="feature-card">
                        <div class="feature-icon">
                            <i class="fas fa-bolt"></i>
                        </div>
                        <h4>Instant Withdrawals</h4>
                        <p>Withdraw your winnings instantly to your bank account or UPI</p>
                    </div>
                </div>

                <div class="col-md-4" data-aos="fade-up" data-aos-delay="300">
                    <div class="feature-card">
                        <div class="feature-icon">
                            <i class="fas fa-headset"></i>
                        </div>
                        <h4>24/7 Support</h4>
                        <p>Our support team is always available to help you with any issues</p>
                    </div>
                </div>

                <div class="col-md-4" data-aos="fade-up" data-aos-delay="400">
                    <div class="feature-card">
                        <div class="feature-icon">
                            <i class="fas fa-trophy"></i>
                        </div>
                        <h4>Big Wins</h4>
                        <p>Win up to ₹1,00,000 in a single game with our high-stakes tables</p>
                    </div>
                </div>

                <div class="col-md-4" data-aos="fade-up" data-aos-delay="500">
                    <div class="feature-card">
                        <div class="feature-icon">
                            <i class="fas fa-users"></i>
                        </div>
                        <h4>Real Players</h4>
                        <p>Play against real opponents, not bots, for a fair gaming experience</p>
                    </div>
                </div>

                <div class="col-md-4" data-aos="fade-up" data-aos-delay="600">
                    <div class="feature-card">
                        <div class="feature-icon">
                            <i class="fas fa-mobile-alt"></i>
                        </div>
                        <h4>Mobile Friendly</h4>
                        <p>Play seamlessly on your mobile device anytime, anywhere</p>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- How It Works Section -->
    <section class="how-it-works-section" id="how-it-works">
        <div class="container">
            <div class="section-header text-center" data-aos="fade-up">
                <span class="section-subtitle">SIMPLE PROCESS</span>
                <h2 class="section-title">How to <span class="text-gradient">Start Playing</span></h2>
                <p class="section-description">
                    Get started in just a few simple steps
                </p>
            </div>

            <div class="row mt-5">
                <div class="col-lg-3 col-md-6 mb-4" data-aos="fade-up" data-aos-delay="100">
                    <div class="step-card">
                        <div class="step-number">1</div>
                        <div class="step-icon">
                            <i class="fas fa-user-plus"></i>
                        </div>
                        <h4>Create Account</h4>
                        <p>Sign up with your email or phone number in seconds</p>
                    </div>
                </div>

                <div class="col-lg-3 col-md-6 mb-4" data-aos="fade-up" data-aos-delay="200">
                    <div class="step-card">
                        <div class="step-number">2</div>
                        <div class="step-icon">
                            <i class="fas fa-wallet"></i>
                        </div>
                        <h4>Add Funds</h4>
                        <p>Deposit money securely via UPI, card, or netbanking</p>
                    </div>
                </div>

                <div class="col-lg-3 col-md-6 mb-4" data-aos="fade-up" data-aos-delay="300">
                    <div class="step-card">
                        <div class="step-number">3</div>
                        <div class="step-icon">
                            <i class="fas fa-gamepad"></i>
                        </div>
                        <h4>Play & Win</h4>
                        <p>Join games and compete with players to win cash</p>
                    </div>
                </div>

                <div class="col-lg-3 col-md-6 mb-4" data-aos="fade-up" data-aos-delay="400">
                    <div class="step-card">
                        <div class="step-number">4</div>
                        <div class="step-icon">
                            <i class="fas fa-hand-holding-usd"></i>
                        </div>
                        <h4>Withdraw</h4>
                        <p>Withdraw your winnings instantly to your bank account</p>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Games Preview Section -->
    <section class="games-preview-section">
        <div class="container">
            <div class="section-header text-center" data-aos="fade-up">
                <span class="section-subtitle">PLAY NOW</span>
                <h2 class="section-title">Choose Your <span class="text-gradient">Betting Range</span></h2>
                <p class="section-description">
                    Select from multiple game categories based on your budget
                </p>
            </div>

            <div class="row mt-5">
                <div class="col-md-6 mb-4" data-aos="fade-right">
                    <div class="game-card beginner-card">
                        <div class="game-card-content">
                            <span class="game-badge beginner">BEGINNER</span>
                            <h3>₹100 - ₹25,000</h3>
                            <p>Perfect for beginners and casual players. Start with small bets and learn the game.</p>
                            <ul class="game-features">
                                <li><i class="fas fa-check-circle text-success"></i> Minimum bet: ₹100</li>
                                <li><i class="fas fa-check-circle text-success"></i> Maximum bet: ₹25,000</li>
                                <li><i class="fas fa-check-circle text-success"></i> Win up to ₹50,000</li>
                            </ul>
                            <a href="/games?range=100-25000" class="btn btn-outline-light">Play Now →</a>
                        </div>
                    </div>
                </div>

                <div class="col-md-6 mb-4" data-aos="fade-left">
                    <div class="game-card pro-card">
                        <div class="game-card-content">
                            <span class="game-badge pro">PRO</span>
                            <h3>₹25,000 - ₹1,00,000</h3>
                            <p>For professional players looking for high-stakes action and big wins.</p>
                            <ul class="game-features">
