                                <li><i class="fas fa-check-circle text-success"></i> Maximum bet: ₹1,00,000</li>
                                <li><i class="fas fa-check-circle text-success"></i> Win up to ₹2,00,000</li>
                            </ul>
                            <a href="/games?range=25000-100000" class="btn btn-outline-light">Play Now →</a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

