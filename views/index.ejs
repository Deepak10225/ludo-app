                        <% if (!user) { %>
                            <a href="/register" class="btn btn-warning btn-lg">
                                <i class="fas fa-user-plus"></i> Create Free Account
                            </a>
                            <% } else { %>
                                <a href="/games" class="btn btn-warning btn-lg">
                                    <i class="fas fa-gamepad"></i> Play Now
                                </a>
                                <% } %>
