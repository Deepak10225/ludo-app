<script src="https://unpkg.com/aos@2.3.1/dist/aos.js"></script>
<script>
    // Initialize AOS
    AOS.init({
        duration: 1000,
        once: true,
        offset: 100
    });

    // Navbar scroll effect
    window.addEventListener('scroll', function () {
        if (window.scrollY > 50) {
            document.querySelector('.navbar').classList.add('scrolled');
        } else {
            document.querySelector('.navbar').classList.remove('scrolled');
        }
    });
</script>
<script>
    // Yeh script hamburger menu ko khud handle karega - Bootstrap par depend nahi karega
    (function () {
        // Jab page load ho
        document.addEventListener('DOMContentLoaded', function () {
            var toggler = document.querySelector('.navbar-toggler');
            var menu = document.getElementById('navbarNav');

            if (!toggler || !menu) return;

            // Menu open/close function
            function toggleMenu() {
                if (menu.classList.contains('show')) {
                    menu.classList.remove('show');
                    toggler.classList.add('collapsed');
                    toggler.setAttribute('aria-expanded', 'false');
                } else {
                    menu.classList.add('show');
                    toggler.classList.remove('collapsed');
                    toggler.setAttribute('aria-expanded', 'true');
                }
            }

            // Toggler click event
            toggler.addEventListener('click', function (e) {
                e.preventDefault();
                e.stopPropagation();
                toggleMenu();
            });

            // Jab koi link click ho to mobile mein menu band ho
            var links = menu.querySelectorAll('.nav-link');
            links.forEach(function (link) {
                link.addEventListener('click', function () {
                    if (window.innerWidth < 992 && menu.classList.contains('show')) {
                        menu.classList.remove('show');
                        toggler.classList.add('collapsed');
                        toggler.setAttribute('aria-expanded', 'false');
                    }
                });
            });

            // Bahar click karo to menu band ho (mobile mein)
            document.addEventListener('click', function (e) {
                if (window.innerWidth < 992 &&
                    menu.classList.contains('show') &&
                    !menu.contains(e.target) &&
                    !toggler.contains(e.target)) {
                    menu.classList.remove('show');
                    toggler.classList.add('collapsed');
                    toggler.setAttribute('aria-expanded', 'false');
                }
            });

            // Window resize par agar mobile se desktop pe jaye to menu band ho
            window.addEventListener('resize', function () {
                if (window.innerWidth >= 992 && menu.classList.contains('show')) {
                    menu.classList.remove('show');
                    toggler.classList.add('collapsed');
                    toggler.setAttribute('aria-expanded', 'false');
                }
            });
        });
    })();
</script>
<script src="/js/main.js"></script>

